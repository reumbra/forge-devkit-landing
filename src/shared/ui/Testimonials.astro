---
import type { TestimonialsConfig } from "@shared/config/testimonials";
import SectionLabel from "./SectionLabel.astro";
import Card from "./Card.astro";
import Badge from "./Badge.astro";

interface Props {
	config: TestimonialsConfig;
}

const { config } = Astro.props;

const tierColor: Record<string, string> = {
	Starter: "text-text-muted",
	Pro: "text-secondary",
	Complete: "text-secondary",
};
---

<section id="testimonials" class="py-12 md:py-24 lg:py-32">
	<div class="mx-auto w-full max-w-[1200px] px-6 md:px-12 lg:px-16">
		{/* Section label + headline */}
		<div class="fade-up mb-10 text-center">
			<SectionLabel text={config.sectionLabel} />
			<h2
				class="mt-4 font-sans text-[36px] font-bold leading-[1.1] tracking-[-0.02em] text-text md:text-[48px]"
			>
				{config.headline}
			</h2>
		</div>

		{/* Metric pills */}
		<div class="fade-up mb-16 flex flex-wrap items-center justify-center gap-4">
			{
				config.metrics.map((metric) => (
					<span class="inline-flex items-center gap-2 rounded-full border border-card bg-surface px-5 py-2.5">
						<span class="font-sans text-[20px] font-bold leading-[1] text-secondary">
							{metric.value}
						</span>
						<span class="font-sans text-[14px] text-text-muted">
							{metric.label}
						</span>
					</span>
				))
			}
		</div>

		{/* Testimonial cards - 2 columns */}
		<div class="grid gap-6 md:grid-cols-2">
			{
				config.testimonials.map((t) => (
					<Card hover={false} padding="compact">
						{/* Quote */}
						<blockquote class="font-sans text-[15px] italic leading-[1.7] text-text-secondary">
							"{t.quote}"
						</blockquote>

						{/* Author line */}
						<div class="mt-5 flex items-center justify-between">
							<div>
								<p class="font-sans text-[15px] font-semibold text-text">
									{t.name}
								</p>
								<p class="font-sans text-[13px] text-text-muted">
									{t.role}{t.company !== "Solo" ? ` - ${t.company}` : ""}
								</p>
							</div>
							<Badge text={t.tier} size="sm" />
						</div>
					</Card>
				))
			}
		</div>
	</div>
</section>
