---
/**
 * Language switcher toggle - EN / RU.
 * Reads current locale from Astro, computes the alternate-language path,
 * and stores choice in localStorage so auto-detect doesn't override it.
 */
interface Props {
	class?: string;
}

const locale = Astro.currentLocale ?? "en";
const currentPath = Astro.url.pathname;

const alternatePath = locale === "ru"
	? (currentPath.replace(/^\/ru/, "") || "/")
	: `/ru${currentPath === "/" ? "" : currentPath}`;
---

<a
	href={alternatePath}
	data-lang-switch
	class:list={[
		"inline-flex items-center gap-1.5 rounded-full border px-3 py-1 font-mono text-[12px] tracking-[0.05em] transition-colors duration-200",
		"border-card text-text-muted hover:border-secondary/40 hover:text-text cursor-pointer",
		Astro.props.class,
	]}
	aria-label={locale === "ru" ? "Switch to English" : "Переключить на русский"}
>
	<span class:list={[locale === "en" ? "text-text font-medium" : "text-text-muted"]}>EN</span>
	<span class="text-text-muted/40">/</span>
	<span class:list={[locale === "ru" ? "text-text font-medium" : "text-text-muted"]}>RU</span>
</a>

<script>
	// Store language preference on click so auto-detect doesn't override it
	document.querySelectorAll<HTMLAnchorElement>("[data-lang-switch]").forEach((el) => {
		el.addEventListener("click", () => {
			const href = el.getAttribute("href") ?? "/";
			const targetLocale = href.startsWith("/ru") ? "ru" : "en";
			localStorage.setItem("forge-locale", targetLocale);
		});
	});
</script>
