---
/**
 * Animated Terminal Shell - reusable container for animated demos.
 *
 * Accepts scenario content via <slot />. Content should use:
 *   .at-line[data-phase][data-delay]  - animated lines (hidden, revealed by delay)
 *   .at-typed[data-text]              - typed text effect (phase 1 command)
 *
 * AIDA psychology baked into the animation engine:
 *   Phase 1: Hook (command typed)
 *   Phase 2+: Progressive reveal with configurable delays
 *
 * Triggers on scroll via IntersectionObserver. Falls back to static if JS disabled.
 */
interface Props {
	class?: string;
	/** Auto-start animation when scrolled into view (default: true) */
	autoplay?: boolean;
	/** Show replay button after animation completes (default: true) */
	showReplay?: boolean;
	/** Compact mode for guide page - smaller min-height (default: false) */
	compact?: boolean;
}

const { class: className, autoplay = true, showReplay = true, compact = false } = Astro.props;
const heightClass = compact
	? "min-h-[220px] sm:min-h-[240px] md:min-h-[260px]"
	: "min-h-[320px] sm:min-h-[380px] md:min-h-[420px]";
---

<div
	class:list={["animated-terminal relative", className]}
	data-autoplay={autoplay}
	data-show-replay={showReplay}
>
	{/* Ambient glow */}
	<div
		class="glow-terminal pointer-events-none absolute -inset-8 md:-inset-12 -z-10 blur-[80px] md:blur-[140px] opacity-60"
	></div>

	<div
		class="overflow-hidden rounded-[var(--radius-card)] border-card bg-surface-deep text-left relative"
	>
		{/* Title bar */}
		<div class="flex items-center gap-2 px-4 py-3 border-b border-[rgba(118,73,196,0.06)]">
			<span class="block h-[10px] w-[10px] rounded-full bg-[#FF5F56]"></span>
			<span class="block h-[10px] w-[10px] rounded-full bg-[#FFBD2E]"></span>
			<span class="block h-[10px] w-[10px] rounded-full bg-[#27C93F]"></span>
			<span class="ml-2 font-mono text-[11px] text-text-muted">Terminal</span>
		</div>

		{/* Terminal content - scenario injected via slot */}
		<div class:list={["at-content overflow-x-auto p-5 font-mono text-[11px] sm:text-[12px] md:text-[13px] leading-[1.7] text-text-secondary", heightClass]}>
			<slot />
		</div>
	</div>

	{/* Replay button - shown after animation completes */}
	<button
		class="at-replay hidden absolute bottom-4 right-4 px-3 py-1.5 rounded-lg bg-[rgba(118,73,196,0.15)] text-[#9A75EA] text-[12px] font-mono hover:bg-[rgba(118,73,196,0.25)] transition-colors cursor-pointer border border-[rgba(118,73,196,0.2)]"
		aria-label="Replay animation"
	>
		&#8634; Replay
	</button>

	{/* Blinking cursor */}
	<style>
		/* :global() needed because .at-line/.at-cursor live in slot content (different Astro cid) */
		:global(.at-cursor)::after {
			content: "▋";
			color: #9A75EA;
			animation: at-blink 1s step-end infinite;
			margin-left: 1px;
		}
		@keyframes at-blink {
			0%, 100% { opacity: 1; }
			50% { opacity: 0; }
		}

		/* Initial state: all lines hidden */
		.animated-terminal :global(.at-line) {
			opacity: 0;
			transform: translateY(4px);
			transition: opacity 0.25s ease, transform 0.25s ease;
		}
		.animated-terminal :global(.at-line.at-visible) {
			opacity: 1;
			transform: translateY(0);
		}

		/* No-JS fallback: show everything */
		@media (scripting: none) {
			.animated-terminal :global(.at-line) {
				opacity: 1;
				transform: none;
			}
		}
	</style>
</div>

<script>
	function initAnimatedTerminals() {
		document.querySelectorAll<HTMLElement>(".animated-terminal").forEach((terminal) => {
			const lines = terminal.querySelectorAll<HTMLElement>(".at-line");
			const replayBtn = terminal.querySelector<HTMLButtonElement>(".at-replay");
			const typedEl = terminal.querySelector<HTMLElement>(".at-typed");
			const autoplay = terminal.dataset.autoplay !== "false";
			const showReplay = terminal.dataset.showReplay !== "false";

			let hasPlayed = false;
			let timeouts: number[] = [];

			function reset() {
				timeouts.forEach(clearTimeout);
				timeouts = [];
				lines.forEach((line) => {
					line.classList.remove("at-visible");
				});
				if (typedEl) {
					typedEl.textContent = "";
					typedEl.classList.remove("at-cursor");
				}
				if (replayBtn) replayBtn.classList.add("hidden");
			}

			function typeText(el: HTMLElement, text: string, speed: number, callback: () => void) {
				let i = 0;
				el.classList.add("at-cursor");
				function tick() {
					if (i < text.length) {
						el.textContent += text[i];
						i++;
						timeouts.push(window.setTimeout(tick, speed));
					} else {
						el.classList.remove("at-cursor");
						callback();
					}
				}
				tick();
			}

			function play() {
				reset();

				// Phase 1: Type the command
				const commandText = typedEl?.dataset.text || "forge setup";
				const typingDuration = commandText.length * 55; // ~55ms per char

				if (typedEl) {
					const promptLine = typedEl.closest(".at-line");
					if (promptLine) {
						promptLine.classList.add("at-visible");
					}
					typeText(typedEl, commandText, 55, () => {
						// After typing, reveal remaining lines by delay
						revealLines(typingDuration);
					});
				} else {
					revealLines(0);
				}
			}

			function revealLines(baseOffset: number) {
				lines.forEach((line) => {
					if (line.dataset.phase === "1") return; // Already shown
					const delay = parseInt(line.dataset.delay || "0", 10) + baseOffset;
					timeouts.push(
						window.setTimeout(() => {
							line.classList.add("at-visible");
						}, delay)
					);
				});

				// Show replay button after last line
				const maxDelay = Array.from(lines).reduce((max, line) => {
					return Math.max(max, parseInt(line.dataset.delay || "0", 10));
				}, 0);

				if (showReplay && replayBtn) {
					timeouts.push(
						window.setTimeout(() => {
							replayBtn.classList.remove("hidden");
						}, maxDelay + baseOffset + 1500)
					);
				}
			}

			// Replay handler
			if (replayBtn) {
				replayBtn.addEventListener("click", () => {
					hasPlayed = false;
					play();
				});
			}

			// IntersectionObserver for autoplay
			if (autoplay) {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting && !hasPlayed) {
								hasPlayed = true;
								play();
							}
						});
					},
					{ threshold: 0.3 }
				);
				observer.observe(terminal);
			} else {
				// If not autoplay, show all lines immediately
				lines.forEach((line) => line.classList.add("at-visible"));
				if (typedEl) {
					typedEl.textContent = typedEl.dataset.text || "";
				}
			}

			// Respect reduced motion
			if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
				lines.forEach((line) => line.classList.add("at-visible"));
				if (typedEl) {
					typedEl.textContent = typedEl.dataset.text || "";
					typedEl.classList.remove("at-cursor");
				}
			}
		});
	}

	// Run on initial load and on Astro view transitions
	initAnimatedTerminals();
	document.addEventListener("astro:after-swap", initAnimatedTerminals);
</script>
