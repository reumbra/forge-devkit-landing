---
import Container from "./Container.astro";

interface Props {
	title: string;
	items: { role: string; benefit: string }[];
}

const { title, items } = Astro.props;
---

<section class="py-12 md:py-20 border-t border-card">
	<Container>
		<h2 class="font-sans text-[28px] font-bold text-text md:text-[36px] mb-10">
			{title}
		</h2>
		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{items.map((item) => (
				<div class="rounded-[14px] border border-card bg-surface p-5">
					<h3 class="font-mono text-[14px] font-medium text-secondary">
						{item.role}
					</h3>
					<p class="mt-2 font-sans text-[13px] text-text-muted leading-[1.6]">
						{item.benefit}
					</p>
				</div>
			))}
		</div>
	</Container>
</section>
