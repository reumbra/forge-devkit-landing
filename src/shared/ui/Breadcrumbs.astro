---
import { localePath } from "@shared/utils/locale";

interface BreadcrumbItem {
	label: string;
	href?: string;
}

interface Props {
	items: BreadcrumbItem[];
}

const { items } = Astro.props;
const locale = Astro.currentLocale;
const lp = (path: string) => localePath(path, locale);
const homeLabel = locale === "ru" ? "Главная" : "Home";
const allItems = [{ label: homeLabel, href: lp("/") }, ...items.map(item => ({
	...item,
	href: item.href ? lp(item.href) : undefined,
}))];

const siteOrigin = Astro.site?.origin ?? "https://reumbra.com";
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: allItems.map((item, i) => ({
		"@type": "ListItem",
		position: i + 1,
		name: item.label,
		...(item.href ? { item: `${siteOrigin}${item.href}` } : {}),
	})),
};
---

<nav aria-label="Breadcrumb" class="font-sans text-[13px] text-text-muted">
	<ol class="flex items-center gap-1.5 flex-wrap">
		{allItems.map((item, i) => (
			<li class="flex items-center gap-1.5">
				{i > 0 && (
					<svg class="w-3 h-3 opacity-40" viewBox="0 0 12 12" fill="none" aria-hidden="true">
						<path d="M4.5 2.5L7.5 6L4.5 9.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
					</svg>
				)}
				{item.href && i < allItems.length - 1 ? (
					<a href={item.href} class="hover:text-white transition-colors duration-200">
						{item.label}
					</a>
				) : (
					<span class="text-text" aria-current={i === allItems.length - 1 ? "page" : undefined}>
						{item.label}
					</span>
				)}
			</li>
		))}
	</ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
