---
import Container from "@shared/ui/Container.astro";
import TerminalSnippet from "@shared/ui/TerminalSnippet.astro";

interface Props {
	title: string;
	language: string;
	code: string;
}

const { title, language, code } = Astro.props;
const isRu = Astro.currentLocale === "ru";
---

<section class="py-12 md:py-20 border-t border-card">
	<Container>
		<h2 class="font-sans text-[28px] font-bold text-text md:text-[36px] mb-6">
			{isRu ? "Пример вывода" : "Sample output"}
		</h2>
		<p class="font-sans text-[14px] text-text-muted mb-8 max-w-2xl">
			{isRu ? "Реальный пример того, что генерирует модуль." : "A real-world example of what this module produces."}
		</p>
		<TerminalSnippet title={title}>
			<pre class="whitespace-pre-wrap"><code set:html={code} /></pre>
		</TerminalSnippet>
	</Container>
</section>
