---
import Container from "@shared/ui/Container.astro";
import Button from "@shared/ui/Button.astro";

interface Props {
	name: string;
	tier: string;
	tierPrice: string;
}

const { name, tier, tierPrice } = Astro.props;
---

<section class="py-16 md:py-24 border-t border-card">
	<Container>
		<div class="text-center">
			<h2 class="font-sans text-[28px] font-bold text-text md:text-[36px]">
				Get started with {name}
			</h2>
			<div class="mt-6 flex items-center justify-center gap-4">
				<Button variant="primary" href="/pricing">
					Get {tier} &mdash; {tierPrice} &rarr;
				</Button>
			</div>
			<p class="mt-4">
				<a href="/modules" class="font-sans text-[14px] text-secondary hover:text-text transition-colors duration-200">
					See all modules &rarr;
				</a>
			</p>
		</div>
	</Container>
</section>
