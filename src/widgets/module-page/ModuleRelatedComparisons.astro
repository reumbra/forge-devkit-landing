---
import Container from "@shared/ui/Container.astro";
import { localePath } from "@shared/utils/locale";

interface Props {
	comparisons: { label: string; href: string }[];
	heading: string;
}

const { comparisons, heading } = Astro.props;
const lp = (path: string) => localePath(path, Astro.currentLocale);
---

<section class="py-10 md:py-14 border-t border-card">
	<Container>
		<h2 class="font-sans text-[22px] font-bold text-text md:text-[28px] mb-6">
			{heading}
		</h2>
		<div class="flex flex-wrap gap-3">
			{comparisons.map((c) => (
				<a
					href={lp(c.href)}
					class="inline-flex items-center rounded-[10px] border border-card bg-surface px-4 py-2.5 font-sans text-[14px] text-text transition-all duration-300 hover:border-card-hover hover:-translate-y-0.5"
				>
					<span class="text-secondary mr-2">{"\u2192"}</span>{c.label}
				</a>
			))}
		</div>
	</Container>
</section>
