---
import Container from "@shared/ui/Container.astro";
import { localePath } from "@shared/utils/locale";

interface Props {
	rows: { dimension: string; them: string; forge: string }[];
	target: string;
	moduleName: string;
	moduleSlug: string;
}

const { rows, target, moduleName, moduleSlug } = Astro.props;
const locale = Astro.currentLocale;
const isRu = locale === "ru";

const comparisonSlugMap: Record<string, string> = {
	core: "cursor-rules",
	product: "cursor-rules",
	qa: "cursor-rules",
};
const vsSlug = comparisonSlugMap[moduleSlug];
const lp = (path: string) => localePath(path, locale);
---

<section class="py-12 md:py-20 border-t border-card">
	<Container>
		<h2 class="font-sans text-[28px] font-bold text-text md:text-[36px] mb-2">
			{moduleName} vs {target}
		</h2>
		{vsSlug && (
			<p class="font-sans text-[14px] text-text-muted mb-8">
				{isRu
					? <>Смотрите <a href={lp(`/vs/${vsSlug}`)} class="text-secondary hover:underline">полное сравнение</a> для деталей.</>
					: <>See the <a href={lp(`/vs/${vsSlug}`)} class="text-secondary hover:underline">full comparison</a> for details.</>
				}
			</p>
		)}
		<div class="overflow-x-auto">
			<table class="w-full text-left">
				<thead>
					<tr class="border-b border-card">
						<th class="py-3 pr-4 font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted w-[30%]">{isRu ? "Критерий" : "Dimension"}</th>
						<th class="py-3 pr-4 font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted w-[35%]">{target}</th>
						<th class="py-3 font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-secondary w-[35%]">Forge DevKit</th>
					</tr>
				</thead>
				<tbody>
					{rows.map((row) => (
						<tr class="border-b border-card/50">
							<td class="py-3 pr-4 font-sans text-[14px] text-text">{row.dimension}</td>
							<td class="py-3 pr-4 font-sans text-[14px] text-text-muted">{row.them}</td>
							<td class="py-3 font-sans text-[14px] text-text">{row.forge}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</Container>
</section>
