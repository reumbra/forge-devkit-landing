---
import Container from "@shared/ui/Container.astro";
import { pricingPageI18n } from "@shared/config/pricing-page";
import { i18n } from "@shared/utils/locale";
const pricingPage = i18n(pricingPageI18n, Astro.currentLocale);

const rows = pricingPage.featureTable;
---

<section class="py-12 md:py-20 border-t border-card" data-track-feature-table>
	<Container>
		<h2 class="font-sans text-[28px] font-bold text-text md:text-[36px] mb-10 text-center">
			Feature comparison
		</h2>
		<div class="overflow-x-auto">
			<table class="w-full text-left">
				<thead>
					<tr class="border-b border-card">
						<th class="py-3 pr-4 font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted">Feature</th>
						<th class="py-3 pr-4 font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted">Module</th>
						<th class="py-3 px-4 font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted text-center w-[80px]">Starter</th>
						<th class="py-3 px-4 font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-secondary text-center w-[80px]">Pro</th>
						<th class="py-3 px-4 font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted text-center w-[80px]">Complete</th>
					</tr>
				</thead>
				<tbody>
					{rows.map((row) => (
						<tr class="border-b border-card/50">
							<td class="py-3 pr-4 font-sans text-[14px] text-text">{row.feature}</td>
							<td class="py-3 pr-4 font-mono text-[12px] text-text-muted">{row.module}</td>
							<td class="py-3 px-4 text-center">
								{row.core ? (
									<span class="text-secondary">{"\u2713"}</span>
								) : (
									<span class="text-text-muted opacity-30">{"\u2014"}</span>
								)}
							</td>
							<td class="py-3 px-4 text-center">
								{row.pro ? (
									<span class="text-secondary">{"\u2713"}</span>
								) : (
									<span class="text-text-muted opacity-30">{"\u2014"}</span>
								)}
							</td>
							<td class="py-3 px-4 text-center">
								{row.bundle ? (
									<span class="text-secondary">{"\u2713"}</span>
								) : (
									<span class="text-text-muted opacity-30">{"\u2014"}</span>
								)}
							</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</Container>
</section>
