---
import Container from "@shared/ui/Container.astro";
import { pricingPageI18n } from "@shared/config/pricing-page";
import { i18n } from "@shared/utils/locale";
const pricingPage = i18n(pricingPageI18n, Astro.currentLocale);
---

<section class="py-12 md:py-20 border-t border-card">
	<Container>
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{pricingPage.trustBadges.map((badge) => (
				<div class="text-center">
					<span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[rgba(118,73,196,0.08)] text-[20px] text-secondary">
						{badge.icon}
					</span>
					<h3 class="mt-3 font-sans text-[15px] font-medium text-text">{badge.title}</h3>
					<p class="mt-1 font-sans text-[13px] text-text-muted leading-[1.5]">{badge.description}</p>
				</div>
			))}
		</div>
	</Container>
</section>
