---
import Container from "@shared/ui/Container.astro";
import { pricingPageI18n } from "@shared/config/pricing-page";
import { i18n } from "@shared/utils/locale";
const config = i18n(pricingPageI18n, Astro.currentLocale);
---

<section class="py-12 md:py-16">
	<Container>
		<div class="mx-auto max-w-[720px]">
			<h2 class="font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.01em] text-text md:text-[28px]">
				{config.diyBlock.headline}
			</h2>
			<div class="mt-8 space-y-6">
				{config.diyBlock.points.map((point) => (
					<div>
						<h3 class="font-sans text-[16px] font-semibold text-text">
							{point.title}
						</h3>
						<p class="mt-1 font-sans text-[15px] leading-[1.6] text-text-secondary">
							{point.description}
						</p>
					</div>
				))}
			</div>
		</div>
	</Container>
</section>
