---
import Container from "@shared/ui/Container.astro";
import AccordionItem from "@shared/ui/AccordionItem.astro";
import { pricingPageI18n } from "@shared/config/pricing-page";
import { i18n } from "@shared/utils/locale";
const pricingPage = i18n(pricingPageI18n, Astro.currentLocale);
---

<section class="py-12 md:py-20 border-t border-card">
	<Container class="max-w-[720px]">
		<h2 class="font-sans text-[28px] font-bold text-text md:text-[36px] mb-10 text-center">
			Pricing FAQ
		</h2>
		<div class="space-y-2">
			{pricingPage.faq.map((item) => (
				<AccordionItem question={item.question} answer={item.answer} />
			))}
		</div>
	</Container>
</section>
