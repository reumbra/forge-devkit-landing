---
import Container from "@shared/ui/Container.astro";
import Button from "@shared/ui/Button.astro";
import SectionLabel from "@shared/ui/SectionLabel.astro";
import AnimatedTerminal from "@shared/ui/AnimatedTerminal.astro";
import SetupBackend from "@shared/ui/scenarios/SetupBackend.astro";
import { heroI18n } from "@shared/config/hero";
import { socialProofI18n } from "@shared/config/social-proof";
import { localePath, i18n } from "@shared/utils/locale";

const lp = (path: string) => localePath(path, Astro.currentLocale);
const hero = i18n(heroI18n, Astro.currentLocale);
const socialProof = i18n(socialProofI18n, Astro.currentLocale);
const { sectionLabel, headline, subheadline, ctas } = hero;
---

<section id="hero" class="flex min-h-screen items-center py-32 md:py-40">
	<Container class="flex flex-col items-center text-center">
		{/* Section label */}
		<div class="mb-6">
			<SectionLabel text={sectionLabel} />
		</div>

		{/* Headline */}
		<h1
			class="font-sans text-[36px] md:text-[48px] lg:text-[64px] font-black leading-[1.1] tracking-[-0.02em] text-text max-w-[720px] mx-auto mb-6"
		>
			{headline}
		</h1>

		{/* Subheadline */}
		<p
			class="font-sans text-[16px] md:text-[18px] lg:text-[20px] font-normal leading-[1.5] text-text-secondary max-w-[600px] mx-auto mb-10"
		>
			{subheadline}
		</p>

		{/* CTA buttons */}
		<div class="flex flex-col md:flex-row items-center gap-4 mb-10 w-full md:w-auto">
			{ctas.map((cta) => (
				<Button variant={cta.variant} href={lp(cta.href)}>
					{cta.label}
				</Button>
			))}
		</div>

		{/* Social proof bar */}
		<div class="mb-16 flex flex-wrap items-center justify-center gap-6 md:gap-8">
			{socialProof.stats.map((stat, i) => (
				<>
					{i > 0 && (
						<span class="hidden text-text-muted opacity-30 sm:inline" aria-hidden="true">|</span>
					)}
					<div class="flex items-baseline gap-1.5">
						<span class="font-mono text-[14px] font-medium text-secondary">{stat.value}</span>
						<span class="font-sans text-[13px] text-text-muted">{stat.label}</span>
					</div>
				</>
			))}
		</div>

		{/* Animated terminal demo - forge setup in action */}
		<div class="w-full max-w-[680px]">
			<AnimatedTerminal>
				<SetupBackend />
			</AnimatedTerminal>
		</div>
	</Container>
</section>
