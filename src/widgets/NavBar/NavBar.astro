---
import Container from "@shared/ui/Container.astro";
import Button from "@shared/ui/Button.astro";
import ReumbraLogo from "@shared/ui/ReumbraLogo.astro";
import { navigationI18n } from "@shared/config/navigation";
import { localePath, i18n } from "@shared/utils/locale";
import LanguageSwitcher from "@shared/ui/LanguageSwitcher.astro";

const locale = Astro.currentLocale;
const lp = (path: string) => localePath(path, locale);
const { logo, links, cta } = i18n(navigationI18n, locale);
const viewAllLabel = locale === "ru" ? "Смотреть все модули" : "View all modules";
---

<nav
	class="fixed inset-x-0 top-0 z-50 bg-nav border-b border-card"
>
	{/* Scroll progress bar */}
	<div
		id="scroll-progress"
		class="absolute bottom-0 left-0 h-[2px] bg-primary transition-none"
		style="width: 0%"
		aria-hidden="true"
	></div>
	<Container class="flex items-center justify-between h-[64px] md:h-[72px]">
		{/* Logo */}
		<a href={lp("/")} class="flex items-center gap-2 text-text font-sans text-[15px] font-medium">
			<ReumbraLogo size={18} class="text-secondary" />
			<span>{logo}</span>
		</a>

		{/* Desktop nav links */}
		<ul class="hidden md:flex items-center gap-6">
			{links.map((link) => (
				<li class={link.children ? "relative" : ""}>
					{link.children ? (
						<>
							{/* Dropdown trigger */}
							<button
								type="button"
								data-dropdown-trigger
								data-nav-link={lp(link.href)}
								class="nav-link flex items-center gap-1 font-sans text-[14px] font-medium text-text-muted hover:text-white transition-colors duration-300 ease-in-out cursor-pointer"
							>
								{link.label}
								<svg class="dropdown-chevron w-2.5 h-2.5 transition-transform duration-200" viewBox="0 0 10 6" fill="none">
									<path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
								</svg>
							</button>

							{/* Dropdown panel */}
							<div
								data-dropdown-panel
								class="dropdown-panel absolute left-1/2 top-full -translate-x-1/2 mt-4 hidden opacity-0 -translate-y-2 transition-all duration-200 ease-out"
							>
								<div class="w-[480px] rounded-[14px] border border-card bg-surface shadow-[0_16px_48px_rgba(0,0,0,0.4)] backdrop-blur-[16px] p-6">
									<div class="grid grid-cols-2 gap-6">
										{link.children.map((column) => (
											<div>
												<p class="font-mono text-[11px] font-medium uppercase tracking-[0.15em] text-text-muted mb-4">
													{column.title}
												</p>
												<div class="flex flex-col gap-1">
													{column.items.map((item) => (
														<a
															href={lp(item.href)}
															class="group rounded-lg px-3 py-2 transition-colors duration-200 hover:bg-[rgba(118,73,196,0.06)]"
														>
															<span class="font-mono text-[14px] font-medium text-text">
																<span class="text-secondary mr-1">{"\u25C7"}</span>{item.name}
															</span>
															<p class="mt-0.5 font-sans text-[13px] text-text-muted">
																{item.description}
															</p>
														</a>
													))}
												</div>
											</div>
										))}
									</div>
									{/* Bottom row */}
									<div class="mt-4 border-t border-card pt-3">
										<a
											href={lp(link.href)}
											class="font-sans text-[14px] font-medium text-secondary hover:text-text transition-colors duration-200"
										>
											{viewAllLabel} {"\u2192"}
										</a>
									</div>
								</div>
							</div>
						</>
					) : (
						<a
							href={lp(link.href)}
							data-nav-link={lp(link.href)}
							target={link.external ? "_blank" : undefined}
							rel={link.external ? "noopener noreferrer" : undefined}
							class="nav-link font-sans text-[14px] font-medium text-text-muted hover:text-white transition-colors duration-300 ease-in-out"
						>
							{link.label}
							{link.external && (
								<svg width="10" height="10" viewBox="0 0 12 12" fill="none" class="inline ml-1 opacity-40" aria-hidden="true">
									<path d="M4 1H11V8M11 1L1 11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
								</svg>
							)}
						</a>
					)}
				</li>
			))}
		</ul>

		{/* Desktop: language switcher + CTA */}
		<div class="hidden md:flex items-center gap-4">
			<LanguageSwitcher />
			<Button variant="primary" href={lp(cta.href)}>
				{cta.label}
			</Button>
		</div>

		{/* Mobile hamburger */}
		<button
			type="button"
			id="nav-toggle"
			class="md:hidden flex flex-col justify-center items-center w-11 h-11 gap-[5px]"
			aria-label="Toggle menu"
			aria-expanded="false"
		>
			<span class="nav-bar block w-5 h-[2px] bg-text-muted transition-all duration-300 ease-in-out origin-center"></span>
			<span class="nav-bar block w-5 h-[2px] bg-text-muted transition-all duration-300 ease-in-out"></span>
			<span class="nav-bar block w-5 h-[2px] bg-text-muted transition-all duration-300 ease-in-out origin-center"></span>
		</button>
	</Container>

	{/* Mobile menu */}
	<div
		id="nav-menu"
		class="md:hidden hidden bg-nav border-t border-card"
	>
		<Container class="flex flex-col gap-1 py-4">
			{links.map((link) => (
				<>
					{link.children ? (
						<>
							{/* Mobile: expandable Modules section */}
							<button
								type="button"
								data-mobile-expand
								class="flex items-center justify-between w-full font-sans text-[15px] font-normal text-text-muted hover:text-white transition-colors duration-300 ease-in-out py-3 cursor-pointer"
							>
								{link.label}
								<svg class="mobile-chevron w-3 h-3 transition-transform duration-200" viewBox="0 0 10 6" fill="none">
									<path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
								</svg>
							</button>
							<div data-mobile-panel class="hidden pl-4 pb-2">
								{link.children.map((column) => (
									<>
										{column.items.map((item) => (
											<a
												href={lp(item.href)}
												class="block font-sans text-[14px] text-text-muted hover:text-white transition-colors duration-200 py-2"
											>
												<span class="text-secondary mr-1">{"\u25C7"}</span>{item.name}
											</a>
										))}
									</>
								))}
								<a
									href={lp(link.href)}
									class="block font-sans text-[13px] font-medium text-secondary mt-2 py-2"
								>
									{viewAllLabel} {"\u2192"}
								</a>
							</div>
						</>
					) : (
						<a
							href={lp(link.href)}
							target={link.external ? "_blank" : undefined}
							rel={link.external ? "noopener noreferrer" : undefined}
							class="font-sans text-[15px] font-normal text-text-muted hover:text-white transition-colors duration-300 ease-in-out py-3"
						>
							{link.label}
							{link.external && (
								<svg width="10" height="10" viewBox="0 0 12 12" fill="none" class="inline ml-1 opacity-40" aria-hidden="true">
									<path d="M4 1H11V8M11 1L1 11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
								</svg>
							)}
						</a>
					)}
				</>
			))}
			<div class="flex items-center gap-3 py-3">
				<LanguageSwitcher />
			</div>
			<Button variant="primary" href={lp(cta.href)}>
				{cta.label}
			</Button>
		</Container>
	</div>
</nav>

{/* Mobile menu backdrop — outside nav to avoid stacking context issues */}
<div
	id="nav-backdrop"
	class="fixed inset-0 top-[64px] z-40 hidden bg-black/60 md:hidden"
	aria-hidden="true"
></div>

<script>
	// ── Desktop dropdowns ──
	const triggers = document.querySelectorAll<HTMLButtonElement>("[data-dropdown-trigger]");

	triggers.forEach((trigger) => {
		const container = trigger.closest("li");
		const panel = container?.querySelector<HTMLDivElement>("[data-dropdown-panel]");
		const chevron = trigger.querySelector<SVGElement>(".dropdown-chevron");
		let isOpen = false;
		let closeTimeout: ReturnType<typeof setTimeout> | null = null;

		function open() {
			if (!panel) return;
			if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }
			panel.classList.remove("hidden");
			requestAnimationFrame(() => {
				panel.classList.remove("opacity-0", "-translate-y-2");
				panel.classList.add("opacity-100", "translate-y-0");
			});
			chevron?.style.setProperty("transform", "rotate(180deg)");
			isOpen = true;
		}

		function close() {
			if (!panel) return;
			panel.classList.remove("opacity-100", "translate-y-0");
			panel.classList.add("opacity-0", "-translate-y-2");
			chevron?.style.setProperty("transform", "");
			isOpen = false;
			setTimeout(() => {
				if (!isOpen) panel.classList.add("hidden");
			}, 200);
		}

		function scheduleClose() {
			closeTimeout = setTimeout(close, 150);
		}

		container?.addEventListener("mouseenter", open);
		container?.addEventListener("mouseleave", scheduleClose);

		trigger.addEventListener("click", () => {
			isOpen ? close() : open();
		});

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && isOpen) close();
		});

		document.addEventListener("click", (e) => {
			if (isOpen && !container?.contains(e.target as Node)) {
				close();
			}
		});
	});

	// ── Mobile menu ──
	const toggle = document.getElementById("nav-toggle");
	const menu = document.getElementById("nav-menu");
	const backdrop = document.getElementById("nav-backdrop");

	function openMenu() {
		if (!toggle || !menu) return;
		menu.classList.remove("hidden");
		backdrop?.classList.remove("hidden");
		toggle.setAttribute("aria-expanded", "true");
		document.body.style.overflow = "hidden";

		const bars = toggle.querySelectorAll<HTMLSpanElement>(".nav-bar");
		bars[0].style.transform = "translateY(7px) rotate(45deg)";
		bars[1].style.opacity = "0";
		bars[2].style.transform = "translateY(-7px) rotate(-45deg)";
	}

	function closeMenu() {
		if (!toggle || !menu) return;
		menu.classList.add("hidden");
		backdrop?.classList.add("hidden");
		toggle.setAttribute("aria-expanded", "false");
		document.body.style.overflow = "";

		const bars = toggle.querySelectorAll<HTMLSpanElement>(".nav-bar");
		bars[0].style.transform = "";
		bars[1].style.opacity = "1";
		bars[2].style.transform = "";
	}

	if (toggle && menu) {
		toggle.addEventListener("click", () => {
			const isOpen = !menu.classList.contains("hidden");
			isOpen ? closeMenu() : openMenu();
		});
		menu.querySelectorAll("a").forEach((link) => {
			link.addEventListener("click", closeMenu);
		});
		backdrop?.addEventListener("click", closeMenu);
	}

	// Mobile expandable sections
	document.querySelectorAll<HTMLButtonElement>("[data-mobile-expand]").forEach((btn) => {
		const mobilePanel = btn.nextElementSibling as HTMLDivElement | null;
		const mobileChevron = btn.querySelector<SVGElement>(".mobile-chevron");
		btn.addEventListener("click", () => {
			const isOpen = !mobilePanel?.classList.contains("hidden");
			mobilePanel?.classList.toggle("hidden");
			mobileChevron?.style.setProperty("transform", isOpen ? "" : "rotate(180deg)");
		});
	});

	// ── Scroll progress bar ──
	const progressBar = document.getElementById("scroll-progress");

	function updateProgress() {
		const scrollTop = window.scrollY;
		const docHeight = document.documentElement.scrollHeight - window.innerHeight;
		const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
		if (progressBar) progressBar.style.width = `${progress}%`;
	}

	// ── Active nav link highlighting (route-based) ──
	const navLinks = document.querySelectorAll<HTMLAnchorElement | HTMLButtonElement>("[data-nav-link]");
	const currentPath = window.location.pathname;

	navLinks.forEach((link) => {
		const linkPath = link.getAttribute("data-nav-link") || "";
		const isActive = currentPath === linkPath || (linkPath !== "/" && currentPath.startsWith(linkPath));
		link.classList.toggle("text-white", isActive);
		link.classList.toggle("text-text-muted", !isActive);
	});

	// ── Back-to-top button + floating CTA ──
	const backToTop = document.getElementById("back-to-top");
	const floatingCta = document.getElementById("floating-cta");

	function toggleFloatingEl(el: HTMLElement | null, show: boolean) {
		if (!el) return;
		el.classList.toggle("opacity-0", !show);
		el.classList.toggle("pointer-events-none", !show);
		el.classList.toggle("translate-y-2", !show);
		el.classList.toggle("opacity-100", show);
		el.classList.toggle("pointer-events-auto", show);
		el.classList.toggle("translate-y-0", show);
	}

	function updateFloatingEls() {
		const show = window.scrollY > window.innerHeight;
		toggleFloatingEl(backToTop, show);
		toggleFloatingEl(floatingCta, show);
	}

	backToTop?.addEventListener("click", () => {
		window.scrollTo({ top: 0, behavior: "smooth" });
	});

	// Throttled scroll handler
	let ticking = false;
	window.addEventListener("scroll", () => {
		if (!ticking) {
			requestAnimationFrame(() => {
				updateProgress();
				updateFloatingEls();
				ticking = false;
			});
			ticking = true;
		}
	});

	// Initial state
	updateProgress();
	updateFloatingEls();
</script>
