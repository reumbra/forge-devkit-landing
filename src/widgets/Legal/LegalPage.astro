---
import Container from "@shared/ui/Container.astro";

interface Props {
	title: string;
	effectiveDate?: string;
}

const { title, effectiveDate } = Astro.props;
---

<section class="pt-32 pb-[var(--spacing-section-y)]">
	<Container>
		<div class="mx-auto max-w-[780px]">
			<h1 class="font-sans text-[32px] font-bold leading-[1.2] text-text md:text-[40px]">
				{title}
			</h1>
			{effectiveDate && (
				<p class="mt-3 font-sans text-[14px] text-text-muted">
					Effective date: {effectiveDate}
				</p>
			)}
			<div class="legal-prose mt-10">
				<slot />
			</div>
		</div>
	</Container>
</section>

<style>
	.legal-prose :global(h2) {
		font-size: 22px;
		font-weight: 700;
		line-height: 1.3;
		color: var(--color-text);
		margin-top: 3rem;
		margin-bottom: 0.75rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(118, 73, 196, 0.08);
	}

	.legal-prose :global(h2:first-child) {
		border-top: none;
		padding-top: 0;
		margin-top: 0;
	}

	.legal-prose :global(h3) {
		font-size: 17px;
		font-weight: 700;
		line-height: 1.4;
		color: var(--color-text);
		margin-top: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.legal-prose :global(p) {
		font-size: 15px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 0.75rem;
	}

	.legal-prose :global(ul) {
		list-style: disc;
		padding-left: 1.25rem;
		margin-bottom: 0.75rem;
	}

	.legal-prose :global(li) {
		font-size: 15px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 0.35rem;
	}

	.legal-prose :global(strong) {
		color: var(--color-text);
		font-weight: 600;
	}

	.legal-prose :global(a) {
		color: var(--color-secondary);
		text-decoration: underline;
		text-underline-offset: 2px;
		transition: color var(--transition-base);
	}

	.legal-prose :global(a:hover) {
		color: var(--color-accent-soft);
	}
</style>
