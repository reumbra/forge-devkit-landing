---
import type { GetStaticPaths } from "astro";
import PageLayout from "../../../layouts/PageLayout.astro";
import ComparisonHero from "@widgets/comparison-page/ComparisonHero.astro";
import ComparisonTable from "@widgets/comparison-page/ComparisonTable.astro";
import ComparisonVerdict from "@widgets/comparison-page/ComparisonVerdict.astro";
import { comparisonSlugs } from "@shared/config/comparisons";
import type { ComparisonPageConfig } from "@shared/config/comparisons";

export const getStaticPaths = (() => {
	return comparisonSlugs.map((slug) => ({ params: { slug } }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const mod = await import(`../../../shared/config/comparisons/${slug}.ts`);
const i18nKey = Object.keys(mod).find((k) => k.endsWith("I18n"));
const i18nRecord = i18nKey ? mod[i18nKey] : null;
const config: ComparisonPageConfig = i18nRecord?.ru ?? (Object.values(mod)[0] as ComparisonPageConfig);

const breadcrumbs = [
	{ label: `Forge vs ${config.competitor}` },
];
---

<PageLayout
	title={config.seo.title}
	description={config.seo.description}
	breadcrumbs={breadcrumbs}
>
	<ComparisonHero headline={config.headline} subheadline={config.subheadline} />
	<ComparisonTable rows={config.rows} competitor={config.competitor} />
	<ComparisonVerdict verdict={config.verdict} ctaText={config.ctaText} />
</PageLayout>
