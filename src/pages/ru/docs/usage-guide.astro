---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import DocHighlight from "@shared/ui/DocHighlight.astro";

const modules = [
	{
		id: "core",
		name: "forge-core",
		tier: "Core+",
		tagline: "Фундамент. Одна команда - и AI понимает весь ваш проект.",
		description: "forge-core проводит 7-этапный архитектурный аудит: автоматически определяет стек, слои, соглашения и паттерны. Генерирует dev-скиллы и 50+ гайдрейлов качества, которые AI использует в каждой сессии. Без ручного промпт-инжиниринга. Без повторных объяснений архитектуры.",
		benefits: [
			"Автоматически определяет стек, архитектурные паттерны и соглашения",
			"Генерирует 50+ паттернов качества под ваш проект",
			"Создаёт dev-скиллы, которые AI загружает автоматически",
			"Контролируемые фазы пайплайна не дают AI отклоняться от задачи",
			"15 детекторов рационализации ловят попытки AI срезать углы",
		],
		commands: [
			{
				command: "/forge:setup",
				description: "Визард настройки, дашборд экосистемы, обновление и реконфигурация.",
				subcommands: [
					{ sub: "/forge:setup", detail: "Запустить 7-этапный визард (первый раз) или показать дашборд экосистемы (после настройки)" },
					{ sub: "/forge:setup upgrade --check", detail: "Проверить наличие обновлений плагинов" },
					{ sub: "/forge:setup upgrade", detail: "Применить доступные обновления" },
					{ sub: "/forge:setup reconfigure", detail: "Перезапустить отдельные этапы без полной настройки" },
				],
			},
			{
				command: "/forge:patch",
				description: "Быстрые патчи конфигурации без полного визарда.",
				subcommands: [
					{ sub: "/forge:patch", detail: "Интерактивный режим патча - выберите, что настроить" },
				],
			},
			{
				command: "/dev",
				description: "Начать задачу разработки через сгенерированный пайплайн.",
				subcommands: [
					{ sub: "/dev", detail: "Начать фичу/фикс с использованием dev-скиллов и паттернов качества" },
					{ sub: "/forge:sync", detail: "Синхронизировать артефакты после изменений архитектуры" },
					{ sub: "/forge:close", detail: "Завершить текущую задачу разработки" },
				],
			},
		],
		workflow: "Установка → /forge:setup (7-этапный аудит) → /dev для начала работы. /forge:setup в любой момент для дашборда.",
	},
	{
		id: "product",
		name: "forge-product",
		tier: "Pro+",
		tagline: "Описывайте фичи на человеческом языке. AI строит по спецификации, а не по догадкам.",
		description: "forge-product убирает разрыв между тем, что вы хотите, и тем, что строит AI. Опишите фичу простым языком - модуль сгенерирует user flows, user stories с критериями приёмки и UX-спецификации. Эти артефакты попадают прямо в пайплайн разработки: AI пишет код по проверенным требованиям, а не по своим галлюцинациям.",
		benefits: [
			"9 продуктовых архетипов (SaaS, маркетплейс, API-платформа и др.)",
			"Генерирует user flows, stories и критерии приёмки автоматически",
			"50+ UX-критериев для стабильного качества",
			"Stories попадают напрямую в /dev пайплайн - без копипасты",
			"Поддержка нескольких методологий (Lean, Jobs-to-be-Done и др.)",
		],
		commands: [
			{
				command: "/forge:product-setup",
				description: "Настройка продуктового модуля - архетип, методология, интеграции.",
				subcommands: [
					{ sub: "/forge:product-setup", detail: "Интерактивный визард настройки продуктового модуля" },
				],
			},
			{
				command: "/forge:product",
				description: "Продуктовые операции - фичи, эпики, роадмап, стратегия.",
				subcommands: [
					{ sub: "/forge:product design", detail: "Спроектировать фичу с user flows, stories и критериями приёмки" },
					{ sub: "/forge:product epic", detail: "Создать эпик с разбивкой на stories" },
					{ sub: "/forge:product roadmap", detail: "Сгенерировать или обновить продуктовый роадмап" },
					{ sub: "/forge:product strategy", detail: "Определить или уточнить стратегию (позиционирование, ICP, GTM)" },
				],
			},
		],
		workflow: "/forge:product-setup → /forge:product design для каждой фичи → stories попадают в /dev пайплайн.",
	},
	{
		id: "qa",
		name: "forge-qa",
		tier: "Pro+",
		tagline: "Тесты, которые привязаны к требованиям. Не к догадкам AI.",
		description: "forge-qa генерирует тесты из критериев приёмки, а не из предположений AI. 10 режимов тестирования и 4-уровневая матрица трассируемости: критерии приёмки → юнит-тесты, use cases → E2E-тесты, UX-критерии → визуальные тесты и LLM-as-Judge для оценки качества AI-output. Каждый тест доказывает требование - никаких orphan-тестов, никаких пробелов в покрытии.",
		benefits: [
			"Генерирует тесты из критериев приёмки - не из догадок",
			"4-уровневая трассируемость: AC → юнит, UC → E2E, UX → визуальные, Judge",
			"10 режимов тестирования для разных сценариев",
			"LLM-as-Judge оценивает качество AI-сгенерированного вывода",
			"Quality gates блокируют мердж, пока требования не покрыты",
		],
		commands: [
			{
				command: "/forge:qa-setup",
				description: "Настройка QA-модуля - фреймворки, пороги покрытия, уровень трассируемости.",
				subcommands: [
					{ sub: "/forge:qa-setup", detail: "Интерактивный визард настройки QA" },
				],
			},
			{
				command: "/forge:qa",
				description: "Операции тестирования - генерация, анализ покрытия, quality gates.",
				subcommands: [
					{ sub: "/forge:qa generate", detail: "Сгенерировать тесты из критериев приёмки или user stories" },
					{ sub: "/forge:qa coverage", detail: "Проанализировать покрытие и предложить недостающие тесты" },
					{ sub: "/forge:qa trace", detail: "Показать матрицу трассируемости (AC → тест → код)" },
					{ sub: "/forge:qa judge", detail: "Запустить LLM-as-Judge для оценки качества тестов" },
					{ sub: "/forge:qa gate", detail: "Запустить quality gate проверки перед мерджем" },
				],
			},
		],
		workflow: "/forge:qa-setup → /forge:product design (генерирует AC) → /forge:qa generate → /forge:qa gate перед мерджем.",
	},
	{
		id: "tracker",
		name: "forge-tracker",
		tier: "Pro+",
		tagline: "Бэклог живёт в трекере. Теперь ваш AI тоже его читает.",
		description: "forge-tracker подключает ваш трекер задач к AI-пайплайну разработки. Выберите задачу из GitHub Issues, Linear, ClickUp, Notion или Jira - AI получает полный контекст (описание, критерии приёмки, метки, приоритет) и начинает работу. По завершении синхронизирует статус и привязывает PR к задаче. Больше никакого копирования описаний задач в промпты.",
		benefits: [
			"5 интеграций: GitHub Issues, Linear, ClickUp, Notion, Jira",
			"Выбирайте задачи прямо из трекера - AI получает полный контекст",
			"Автосинхронизация статуса задачи обратно в трекер",
			"Автоматическая привязка PR и коммитов к задачам",
			"Валидация AC гарантирует выполнение требований перед закрытием",
		],
		commands: [
			{
				command: "/forge:tracker-setup",
				description: "Настройка интеграции с трекером - выбор провайдера и подключение.",
				subcommands: [
					{ sub: "/forge:tracker-setup", detail: "Интерактивная настройка трекера (автоопределение доступных интеграций)" },
				],
			},
			{
				command: "/forge:tracker",
				description: "Операции с задачами - выбор, синхронизация, закрытие.",
				subcommands: [
					{ sub: "/forge:tracker pick", detail: "Выбрать задачу из трекера для работы" },
					{ sub: "/forge:tracker sync", detail: "Синхронизировать статус задачи обратно в трекер" },
					{ sub: "/forge:tracker close", detail: "Закрыть задачу с резюме и ссылкой на PR/коммит" },
				],
			},
		],
		workflow: "/forge:tracker-setup → /forge:tracker pick → /dev → /forge:tracker sync → /forge:tracker close.",
	},
	{
		id: "autopilot",
		name: "forge-autopilot",
		tier: "Complete",
		tagline: "3 агента параллельно. Ноль конфликтов при мердже.",
		description: "forge-autopilot управляет автономными AI-участниками как Kubernetes управляет контейнерами. Дайте список фич - модуль проведёт триаж, определит потенциальные конфликты (общие модели, пересекающиеся файлы), сгруппирует неконфликтующие фичи в параллельные волны и развернёт агентов в изолированных worktree. Каждый агент следует полному пайплайну (гайдрейлы, тесты, quality gates). По завершении волны - автомердж и запуск следующей.",
		benefits: [
			"Триаж бэклога классифицирует фичи по сложности и риску",
			"Детекция конфликтов предотвращает редактирование одних файлов разными агентами",
			"Wave-execution запускает неконфликтующие фичи параллельно",
			"3 режима автономности: supervised, semi-auto, full-auto",
			"Автомердж с проверкой quality gates перед слиянием",
		],
		commands: [
			{
				command: "/forge:autopilot",
				description: "Запуск пакетного автономного пайплайна разработки.",
				subcommands: [
					{ sub: "/forge:autopilot --setup", detail: "Настроить режим автономности и источники фич" },
					{ sub: "/forge:autopilot", detail: "Запустить пакет с настроенными источниками (триаж → волны → выполнение)" },
					{ sub: '/forge:autopilot "auth, payments"', detail: "Запустить пакет с конкретными фичами" },
					{ sub: "/forge:autopilot --resume", detail: "Возобновить прерванный пакет с последнего чекпоинта" },
					{ sub: "/forge:autopilot --abort", detail: "Прервать текущий пакет и очистить worktree" },
				],
			},
		],
		workflow: "/forge:autopilot --setup → /forge:autopilot → агенты: триаж, детекция конфликтов, выполнение волнами → ревью результатов.",
	},
	{
		id: "worktree",
		name: "forge-worktree",
		tier: "Complete",
		tagline: "Изолированные ветки без конфликтов портов. Автоматическая очистка.",
		description: "forge-worktree управляет жизненным циклом git worktree для параллельной разработки. Каждый worktree получает свою директорию, смещения Docker-портов и конфигурацию окружения - никаких конфликтов портов между ветками. Три шаблона: Docker backend (с изоляцией портов), Frontend (со смещениями dev-сервера) и Generic. Worktree создаются автоматически forge-autopilot или вручную.",
		benefits: [
			"3 шаблона: Docker backend, Frontend, Generic",
			"Автоматическая изоляция Docker-портов для каждого worktree",
			"Автоочистка при мердже веток",
			"Интеграция с forge-autopilot для автономного провижининга",
			"Нулевая ручная настройка изоляции окружения",
		],
		commands: [
			{
				command: "/forge:worktree-setup",
				description: "Настройка шаблонов worktree и параметров изоляции.",
				subcommands: [
					{ sub: "/forge:worktree-setup", detail: "Интерактивная настройка worktree - выбор шаблона (Docker backend, Frontend, Generic)" },
				],
			},
		],
		workflow: "/forge:worktree-setup → worktree создаются автоматически forge-autopilot или вручную через git worktree.",
	},
];
---

<DocsLayout
	title="Руководство - Forge DevKit"
	description="Полный справочник команд и модулей Forge DevKit - все 6 модулей."
>
	<h1 class="font-sans text-[36px] md:text-[48px] font-black leading-[1.1] tracking-[-0.02em] text-text mb-4">
		Руководство
	</h1>
	<p class="font-sans text-[18px] md:text-[20px] text-text-secondary leading-[1.6] mb-6">
		Полный гайд по всем 6 модулям Forge DevKit &mdash; что делают, как использовать и зачем нужны.
	</p>
	<p class="text-[15px] text-text-muted leading-[1.7] mb-16">
		Все команды выполняются внутри AI-сессии (Claude Code, Cursor или Claude Desktop). Forge DevKit &mdash; система плагинов, команды становятся доступны после <a href="/ru/docs/getting-started" class="text-secondary hover:underline">установки</a>.
	</p>

	{/* Quick nav */}
	<nav class="mb-16 rounded-[var(--radius-card)] border border-card bg-surface-card p-6">
		<p class="font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted mb-4">Перейти к модулю</p>
		<div class="flex flex-wrap gap-3">
			{modules.map((m) => (
				<a href={`#${m.id}`} class="inline-flex items-center gap-2 rounded-full border border-card px-4 py-1.5 font-mono text-[13px] text-text hover:border-secondary/40 hover:text-secondary transition-colors">
					{m.name}
					<span class="text-[11px] text-text-muted">{m.tier}</span>
				</a>
			))}
		</div>
	</nav>

	{/* Module sections */}
	{modules.map((m) => (
		<section id={m.id} class="mb-20 scroll-mt-24">
			{/* Header */}
			<div class="flex items-baseline gap-3 mb-2">
				<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text">
					{m.name}
				</h2>
				<span class="rounded-full bg-[rgba(118,73,196,0.08)] px-3 py-0.5 font-mono text-[12px] text-secondary">
					{m.tier}
				</span>
			</div>

			{/* Tagline */}
			<p class="font-sans text-[18px] text-text leading-[1.5] font-medium mb-4">
				{m.tagline}
			</p>

			{/* Description */}
			<p class="text-[15px] text-text-secondary leading-[1.7] mb-2">
				{m.description}
			</p>

			{/* Marketing highlights - pain/gain callouts per module */}
			{m.id === "core" && (
				<>
					<DocHighlight variant="pain">
						<strong>Без Forge:</strong> вы тратите 20 минут каждую сессию, объясняя AI свою архитектуру заново. Он забывает ваши NestJS guards, соглашения по слоям, паттерны именования - каждый раз.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>С forge-core:</strong> одна команда <code>/forge:setup</code> - и AI навсегда знает ваш стек, слои и соглашения. Без ручного промпт-инжиниринга. Без повторных объяснений. Навсегда.
					</DocHighlight>
				</>
			)}
			{m.id === "product" && (
				<>
					<DocHighlight variant="pain">
						<strong>Без Forge:</strong> вы описываете фичу расплывчато, AI галлюцинирует требования, строит не то, и вы часами отлаживаете предположения, которые никто не проверял.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>С forge-product:</strong> описывайте фичи на человеческом языке - AI генерирует проверенные user flows, stories и критерии приёмки <em>до</em> написания первой строки кода.
					</DocHighlight>
				</>
			)}
			{m.id === "qa" && (
				<>
					<DocHighlight variant="pain">
						<strong>Без Forge:</strong> AI генерирует тесты с 100% покрытием - всё на моках. Каждый assert проверяет детали реализации. Ноль реального поведения проверено.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>С forge-qa:</strong> каждый тест привязан к критерию приёмки. Никаких orphan-тестов. Никаких пробелов в покрытии. Тесты доказывают требования, а не догадки AI.
					</DocHighlight>
				</>
			)}
			{m.id === "tracker" && (
				<>
					<DocHighlight variant="pain">
						<strong>Без Forge:</strong> вы копируете описания задач из трекера в AI-промпты. Контекст теряется. Обновления статуса - вручную. PR никогда не привязываются к задачам.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>С forge-tracker:</strong> <code>/forge:tracker pick</code> загружает задачу с полным контекстом. По завершении <code>/forge:tracker close</code> синхронизирует статус и привязывает PR - ноль ручных обновлений.
					</DocHighlight>
				</>
			)}
			{m.id === "autopilot" && (
				<>
					<DocHighlight variant="pain">
						<strong>Без Forge:</strong> вы запускаете 3 агента параллельно - все редактируют одну модель User. Вы тратите 4 часа на разрешение merge-конфликтов. Итоговая продуктивность: <em>отрицательная</em>.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>С forge-autopilot:</strong> детекция конфликтов группирует фичи в безопасные волны. Каждый агент получает изолированный worktree с полным пайплайном. Автомердж после прохождения quality gates.
					</DocHighlight>
				</>
			)}
			{m.id === "worktree" && (
				<DocHighlight variant="insight">
					<strong>Зачем worktree?</strong> Каждому параллельному агенту нужна изоляция - своя ветка, порты и окружение. Ручная настройка ненадёжна. forge-worktree автоматизирует весь жизненный цикл, чтобы вы фокусировались на фичах, а не на инфраструктуре.
				</DocHighlight>
			)}

			{/* Benefits */}
			<div class="rounded-[var(--radius-card)] border border-card bg-surface-card p-5 mb-8">
				<p class="font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted mb-3">Что вы получаете</p>
				<ul class="space-y-2">
					{m.benefits.map((b) => (
						<li class="flex items-start gap-2 text-[14px] text-text-secondary leading-[1.6]">
							<span class="text-secondary mt-0.5 shrink-0">&#10003;</span>
							<span>{b}</span>
						</li>
					))}
				</ul>
			</div>

			{/* Commands */}
			<div class="space-y-6 mb-6">
				{m.commands.map((cmd) => (
					<div class="rounded-[var(--radius-card)] border border-card bg-surface-card overflow-hidden">
						<div class="border-b border-card px-5 py-3 flex items-baseline gap-3">
							<code class="font-mono text-[15px] font-medium text-secondary">{cmd.command}</code>
							<span class="text-[13px] text-text-muted">{cmd.description}</span>
						</div>
						<div class="px-5 py-3">
							<table class="w-full">
								<tbody>
									{cmd.subcommands.map((sc) => (
										<tr class="border-b border-card/30 last:border-0">
											<td class="py-2 pr-4 font-mono text-[13px] text-text whitespace-nowrap align-top">{sc.sub}</td>
											<td class="py-2 text-[13px] text-text-muted">{sc.detail}</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					</div>
				))}
			</div>

			{/* Workflow */}
			<div class="rounded-[var(--radius-card)] border border-secondary/15 bg-secondary/5 px-5 py-3">
				<p class="text-[13px]">
					<span class="font-mono text-[12px] font-medium text-secondary mr-2">Типичный workflow:</span>
					<span class="text-text-muted">{m.workflow}</span>
				</p>
			</div>
		</section>
	))}

	{/* Feedback & Bug Reports */}
	<section id="feedback" class="mb-16 scroll-mt-24">
		<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text mb-3">
