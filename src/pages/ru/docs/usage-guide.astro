---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import DocHighlight from "@shared/ui/DocHighlight.astro";

const modules = [
	{
		id: "core",
		name: "forge-core",
		tier: "Core+",
		tagline: "The foundation. One command makes your AI understand your entire project.",
		description: "forge-core runs a 7-gate architecture audit that auto-detects your stack, layers, conventions, and patterns. It generates project-specific dev-skills and 50+ quality guardrails that your AI follows in every session. No manual prompt engineering. No re-explaining your architecture.",
		benefits: [
			"Auto-detects stack, architecture patterns, and conventions",
			"Generates 50+ quality patterns tailored to your project",
			"Creates project-specific dev-skills your AI loads automatically",
			"Scoped pipeline phases prevent AI from going off-track",
			"15 LLM rationalization detectors catch AI shortcuts",
		],
		commands: [
			{
				command: "/forge:setup",
				description: "Setup wizard, ecosystem dashboard, upgrade, and reconfigure.",
				subcommands: [
					{ sub: "/forge:setup", detail: "Run the 7-gate wizard (first time) or show the ecosystem dashboard (after setup)" },
					{ sub: "/forge:setup upgrade --check", detail: "Check for plugin updates" },
					{ sub: "/forge:setup upgrade", detail: "Apply available updates" },
					{ sub: "/forge:setup reconfigure", detail: "Re-run specific gates without full setup" },
				],
			},
			{
				command: "/forge:patch",
				description: "Quick config patches without running the full wizard.",
				subcommands: [
					{ sub: "/forge:patch", detail: "Interactive patch mode — select what to adjust" },
				],
			},
			{
				command: "/dev",
				description: "Start a development task using the generated pipeline.",
				subcommands: [
					{ sub: "/dev", detail: "Begin a feature/fix using your project's dev-skills and quality patterns" },
					{ sub: "/forge:sync", detail: "Sync generated artifacts after architecture changes" },
					{ sub: "/forge:close", detail: "Finalize and close the current development task" },
				],
			},
		],
		workflow: "Install → /forge:setup (7-gate audit) → /dev to start building. Run /forge:setup anytime for dashboard.",
	},
	{
		id: "product",
		name: "forge-product",
		tier: "Pro+",
		tagline: "Describe features in business language. AI builds from spec, not guesswork.",
		description: "forge-product bridges the gap between what you want and what AI builds. Describe a feature in plain language — it generates user flows, user stories with acceptance criteria, and UX specifications. These artifacts feed directly into the development pipeline, so your AI codes from verified requirements instead of hallucinated assumptions.",
		benefits: [
			"9 product archetypes (SaaS, marketplace, API platform, etc.)",
			"Generates user flows, stories, and acceptance criteria automatically",
			"50+ UX criteria library for consistent quality",
			"Stories feed directly into /dev pipeline — zero copy-paste",
			"Supports multiple methodologies (Lean, Jobs-to-be-Done, etc.)",
		],
		commands: [
			{
				command: "/forge:product-setup",
				description: "Configure product design module — select archetype, methodology, integrations.",
				subcommands: [
					{ sub: "/forge:product-setup", detail: "Interactive setup wizard for product module" },
				],
			},
			{
				command: "/forge:product",
				description: "Product design operations — features, epics, roadmap, strategy.",
				subcommands: [
					{ sub: "/forge:product design", detail: "Design a feature with user flows, stories, and acceptance criteria" },
					{ sub: "/forge:product epic", detail: "Create an epic with breakdown into stories" },
					{ sub: "/forge:product roadmap", detail: "Generate or update a product roadmap" },
					{ sub: "/forge:product strategy", detail: "Define or refine product strategy (positioning, ICP, GTM)" },
				],
			},
		],
		workflow: "/forge:product-setup → /forge:product design for each feature → stories feed into /dev pipeline.",
	},
	{
		id: "qa",
		name: "forge-qa",
		tier: "Pro+",
		tagline: "Tests that trace back to requirements. Not AI guesswork.",
		description: "forge-qa generates tests from acceptance criteria, not from AI assumptions. It supports 10 testing modes and maintains a 4-level traceability matrix: acceptance criteria → unit tests, use cases → E2E tests, UX criteria → visual tests, and LLM-as-Judge for AI output quality. Every test proves a requirement — no orphan tests, no missing coverage.",
		benefits: [
			"Generates tests from acceptance criteria — not guesswork",
			"4-level traceability: AC → unit, UC → E2E, UX → visual, Judge",
			"10 testing modes for different scenarios",
			"LLM-as-Judge evaluates AI-generated output quality",
			"Quality gates block merges until requirements are covered",
		],
		commands: [
			{
				command: "/forge:qa-setup",
				description: "Configure QA module — select test frameworks, coverage thresholds, traceability level.",
				subcommands: [
					{ sub: "/forge:qa-setup", detail: "Interactive QA configuration wizard" },
				],
			},
			{
				command: "/forge:qa",
				description: "Test operations — generation, coverage analysis, quality gates.",
				subcommands: [
					{ sub: "/forge:qa generate", detail: "Generate tests from acceptance criteria or user stories" },
					{ sub: "/forge:qa coverage", detail: "Analyze test coverage and suggest missing tests" },
					{ sub: "/forge:qa trace", detail: "Show traceability matrix (AC → test → code)" },
					{ sub: "/forge:qa judge", detail: "Run LLM-as-Judge to evaluate test quality" },
					{ sub: "/forge:qa gate", detail: "Run quality gate checks before merge" },
				],
			},
		],
		workflow: "/forge:qa-setup → /forge:product design (generates AC) → /forge:qa generate → /forge:qa gate before merge.",
	},
	{
		id: "tracker",
		name: "forge-tracker",
		tier: "Pro+",
		tagline: "Your backlog lives in your tracker. Now your AI reads it too.",
		description: "forge-tracker connects your existing task management tool to the AI development pipeline. Pick a task from GitHub Issues, Linear, ClickUp, Notion, or Jira — your AI gets the full context (description, acceptance criteria, labels, priority) and starts working. When done, it syncs status and links the PR back to the task. No more copy-pasting issue descriptions into prompts.",
		benefits: [
			"5 integrations: GitHub Issues, Linear, ClickUp, Notion, Jira",
			"Pick tasks directly from your tracker — AI gets full context",
			"Auto-syncs task status and progress back to tracker",
			"Links PRs and commits to tasks automatically",
			"AC validation ensures task requirements are met before closing",
		],
		commands: [
			{
				command: "/forge:tracker-setup",
				description: "Configure task tracker integration — select provider and connect.",
				subcommands: [
					{ sub: "/forge:tracker-setup", detail: "Interactive tracker setup (auto-detects available integrations)" },
				],
			},
			{
				command: "/forge:tracker",
				description: "Task management operations — pick, sync, close tasks.",
				subcommands: [
					{ sub: "/forge:tracker pick", detail: "Pick a task from your tracker to work on" },
					{ sub: "/forge:tracker sync", detail: "Sync task status and progress back to tracker" },
					{ sub: "/forge:tracker close", detail: "Close task with summary and link to PR/commit" },
				],
			},
		],
		workflow: "/forge:tracker-setup → /forge:tracker pick → /dev → /forge:tracker sync → /forge:tracker close.",
	},
	{
		id: "autopilot",
		name: "forge-autopilot",
		tier: "Bundle",
		tagline: "Run 3 agents in parallel. Zero merge conflicts.",
		description: "forge-autopilot orchestrates autonomous AI teammates like Kubernetes orchestrates containers. Give it a list of features — it triages them, detects potential conflicts (shared models, overlapping files), groups non-conflicting features into parallel waves, and deploys agents to isolated worktrees. Each agent follows your full pipeline (guardrails, tests, quality gates). When a wave completes, it auto-merges and starts the next wave.",
		benefits: [
			"Backlog triage classifies features by complexity and risk",
			"Conflict detection prevents agents from editing the same files",
			"Wave execution runs non-conflicting features in parallel",
			"3 autonomy modes: supervised, semi-auto, full-auto",
			"Auto-merge with quality gate verification before merge",
		],
		commands: [
			{
				command: "/forge:autopilot",
				description: "Launch batch autonomous development pipeline.",
				subcommands: [
					{ sub: "/forge:autopilot --setup", detail: "Configure autonomy mode and feature sources" },
					{ sub: "/forge:autopilot", detail: "Start batch with configured sources (triage → waves → execute)" },
					{ sub: '/forge:autopilot "auth, payments"', detail: "Start batch with specific features" },
					{ sub: "/forge:autopilot --resume", detail: "Resume interrupted batch from last checkpoint" },
					{ sub: "/forge:autopilot --abort", detail: "Abort current batch and clean up worktrees" },
				],
			},
		],
		workflow: "/forge:autopilot --setup → /forge:autopilot → agents triage, detect conflicts, execute in waves → review results.",
	},
	{
		id: "worktree",
		name: "forge-worktree",
		tier: "Bundle",
		tagline: "Isolated branches with zero port conflicts. Automatic cleanup.",
		description: "forge-worktree manages the git worktree lifecycle for parallel development. Each worktree gets its own directory, Docker port offsets, and environment configuration — no more port conflicts between branches. Three templates cover common setups: Docker backend (with port isolation), Frontend (with dev server offsets), and Generic. Worktrees are auto-provisioned by forge-autopilot or created manually.",
		benefits: [
			"3 templates: Docker backend, Frontend, Generic",
			"Automatic Docker port isolation per worktree",
			"Auto-cleanup when branches are merged",
			"Integrates with forge-autopilot for autonomous provisioning",
			"Zero manual configuration for environment isolation",
		],
		commands: [
			{
				command: "/forge:worktree-setup",
				description: "Configure worktree templates and isolation settings.",
				subcommands: [
					{ sub: "/forge:worktree-setup", detail: "Interactive worktree configuration — select template (Docker backend, Frontend, Generic)" },
				],
			},
		],
		workflow: "/forge:worktree-setup → worktrees are auto-provisioned by forge-autopilot or created manually via git worktree.",
	},
];
---

<DocsLayout
	title="Usage Guide — Forge DevKit"
	description="Complete command reference and module guide for all 6 Forge DevKit modules."
>
	<h1 class="font-sans text-[36px] md:text-[48px] font-black leading-[1.1] tracking-[-0.02em] text-text mb-4">
		Usage Guide
	</h1>
	<p class="font-sans text-[18px] md:text-[20px] text-text-secondary leading-[1.6] mb-6">
		Complete guide to all 6 Forge DevKit modules &mdash; what they do, how to use them, and why they matter.
	</p>
	<p class="text-[15px] text-text-muted leading-[1.7] mb-16">
		All commands run inside your AI session (Claude Code, Cursor, or Claude Desktop). Forge DevKit is a plugin system &mdash; commands become available after <a href="/ru/docs/getting-started" class="text-secondary hover:underline">installation</a>.
	</p>

	{/* Quick nav */}
	<nav class="mb-16 rounded-[var(--radius-card)] border border-card bg-surface-card p-6">
		<p class="font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted mb-4">Jump to module</p>
		<div class="flex flex-wrap gap-3">
			{modules.map((m) => (
				<a href={`#${m.id}`} class="inline-flex items-center gap-2 rounded-full border border-card px-4 py-1.5 font-mono text-[13px] text-text hover:border-secondary/40 hover:text-secondary transition-colors">
					{m.name}
					<span class="text-[11px] text-text-muted">{m.tier}</span>
				</a>
			))}
		</div>
	</nav>

	{/* Module sections */}
	{modules.map((m) => (
		<section id={m.id} class="mb-20 scroll-mt-24">
			{/* Header */}
			<div class="flex items-baseline gap-3 mb-2">
				<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text">
					{m.name}
				</h2>
				<span class="rounded-full bg-[rgba(118,73,196,0.08)] px-3 py-0.5 font-mono text-[12px] text-secondary">
					{m.tier}
				</span>
			</div>

			{/* Tagline */}
			<p class="font-sans text-[18px] text-text leading-[1.5] font-medium mb-4">
				{m.tagline}
			</p>

			{/* Description */}
			<p class="text-[15px] text-text-secondary leading-[1.7] mb-2">
				{m.description}
			</p>

			{/* Marketing highlights — pain/gain callouts per module */}
			{m.id === "core" && (
				<>
					<DocHighlight variant="pain">
						<strong>Without Forge:</strong> you spend 20 minutes every session re-explaining your architecture to AI. It forgets your NestJS guards, your layer conventions, your naming patterns — every single time.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>With forge-core:</strong> one <code>/forge:setup</code> and your AI permanently knows your stack, layers, and conventions. No manual prompt engineering. No re-explaining. Ever.
					</DocHighlight>
				</>
			)}
			{m.id === "product" && (
				<>
					<DocHighlight variant="pain">
						<strong>Without Forge:</strong> you describe a feature vaguely, AI hallucinates requirements, builds the wrong thing, and you spend hours debugging assumptions that were never verified.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>With forge-product:</strong> describe features in business language — AI generates verified user flows, stories, and acceptance criteria <em>before</em> writing a single line of code.
					</DocHighlight>
				</>
			)}
			{m.id === "qa" && (
				<>
					<DocHighlight variant="pain">
						<strong>Without Forge:</strong> AI generates tests with 100% coverage — all using mock data. Every assertion tests implementation details. Zero real behavior verified.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>With forge-qa:</strong> every test traces back to an acceptance criterion. No orphan tests. No missing coverage. Tests prove requirements, not AI guesswork.
					</DocHighlight>
				</>
			)}
			{m.id === "tracker" && (
				<>
					<DocHighlight variant="pain">
						<strong>Without Forge:</strong> you copy-paste issue descriptions from your tracker into AI prompts. Context gets lost. Status updates are manual. PRs never link back to tasks.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>With forge-tracker:</strong> <code>/forge:tracker pick</code> pulls the task with full context. When you're done, <code>/forge:tracker close</code> syncs status and links the PR — zero manual updates.
					</DocHighlight>
				</>
			)}
			{m.id === "autopilot" && (
				<>
					<DocHighlight variant="pain">
						<strong>Without Forge:</strong> you run 3 agents in parallel — they all edit the same User model. You spend 4 hours resolving merge conflicts. Net productivity: <em>negative</em>.
					</DocHighlight>
					<DocHighlight variant="gain">
						<strong>With forge-autopilot:</strong> conflict detection groups features into safe waves. Each agent gets an isolated worktree with your full pipeline. Auto-merge after quality gates pass.
					</DocHighlight>
				</>
			)}
			{m.id === "worktree" && (
				<DocHighlight variant="insight">
					<strong>Why worktrees?</strong> Each parallel agent needs isolation — its own branch, ports, and environment. Manual setup is error-prone. forge-worktree automates the entire lifecycle, so you focus on features, not infrastructure.
				</DocHighlight>
			)}

			{/* Benefits */}
			<div class="rounded-[var(--radius-card)] border border-card bg-surface-card p-5 mb-8">
				<p class="font-mono text-[12px] font-medium uppercase tracking-[0.1em] text-text-muted mb-3">What you get</p>
				<ul class="space-y-2">
					{m.benefits.map((b) => (
						<li class="flex items-start gap-2 text-[14px] text-text-secondary leading-[1.6]">
							<span class="text-secondary mt-0.5 shrink-0">&#10003;</span>
							<span>{b}</span>
						</li>
					))}
				</ul>
			</div>

			{/* Commands */}
			<div class="space-y-6 mb-6">
				{m.commands.map((cmd) => (
					<div class="rounded-[var(--radius-card)] border border-card bg-surface-card overflow-hidden">
						<div class="border-b border-card px-5 py-3 flex items-baseline gap-3">
							<code class="font-mono text-[15px] font-medium text-secondary">{cmd.command}</code>
							<span class="text-[13px] text-text-muted">{cmd.description}</span>
						</div>
						<div class="px-5 py-3">
							<table class="w-full">
								<tbody>
									{cmd.subcommands.map((sc) => (
										<tr class="border-b border-card/30 last:border-0">
											<td class="py-2 pr-4 font-mono text-[13px] text-text whitespace-nowrap align-top">{sc.sub}</td>
											<td class="py-2 text-[13px] text-text-muted">{sc.detail}</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					</div>
				))}
			</div>

			{/* Workflow */}
			<div class="rounded-[var(--radius-card)] border border-secondary/15 bg-secondary/5 px-5 py-3">
				<p class="text-[13px]">
					<span class="font-mono text-[12px] font-medium text-secondary mr-2">Typical workflow:</span>
					<span class="text-text-muted">{m.workflow}</span>
				</p>
			</div>
		</section>
	))}

	{/* Feedback & Bug Reports */}
	<section id="feedback" class="mb-16 scroll-mt-24">
		<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text mb-3">
			Feedback & Bug Reports
		</h2>
		<p class="text-[16px] text-text-secondary leading-[1.7] mb-6">
			Found a bug? Have a suggestion? Use the built-in feedback command &mdash; it sends structured reports directly to the Forge team.
		</p>

		<div class="rounded-[var(--radius-card)] border border-card bg-surface-card overflow-hidden mb-6">
			<div class="border-b border-card px-5 py-3 flex items-baseline gap-3">
				<code class="font-mono text-[15px] font-medium text-secondary">/forge:feedback</code>
				<span class="text-[13px] text-text-muted">Send feedback, bug reports, or feature requests.</span>
			</div>
			<div class="px-5 py-3">
				<table class="w-full">
					<tbody>
						<tr class="border-b border-card/30">
							<td class="py-2 pr-4 font-mono text-[13px] text-text whitespace-nowrap align-top">/forge:feedback</td>
							<td class="py-2 text-[13px] text-text-muted">Interactive feedback wizard &mdash; select type (bug, friction, suggestion), describe the issue, auto-attaches session context</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>

		<div class="space-y-4 text-[15px] text-text-secondary leading-[1.7]">
			<p>
				The feedback command collects:
			</p>
			<ul class="list-disc pl-6 space-y-1">
				<li><strong class="text-text">Your description</strong> &mdash; what happened, what you expected</li>
				<li><strong class="text-text">Session context</strong> &mdash; plugin versions, detected stack, execution mode (auto-attached, no manual work)</li>
				<li><strong class="text-text">Feedback type</strong> &mdash; friction (something was hard), bug (something broke), suggestion (feature request)</li>
			</ul>
			<p>
				Reports are sent securely using your license key. No source code or file contents are included &mdash; only metadata and your description.
			</p>
			<p>
				Alternatively, email <a href="mailto:support@reumbra.com" class="text-secondary hover:underline">support@reumbra.com</a> for direct support.
			</p>
		</div>
	</section>

	{/* CTA */}
	<section class="mb-16">
		<div class="rounded-[var(--radius-card)] border border-secondary/20 bg-secondary/5 p-8 text-center">
			<p class="font-sans text-[20px] md:text-[24px] font-bold text-text mb-3">
				Ready to get started?
			</p>
			<p class="text-[16px] text-text-secondary mb-6">
				One-time purchase. 14-day money-back guarantee.
			</p>
			<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
				<a
					href="/pricing"
					class="inline-flex items-center justify-center rounded-[var(--radius-button)] bg-primary px-8 py-3 font-sans text-[15px] font-medium text-white transition-all duration-200 hover:bg-primary-hover"
				>
					Get Forge &mdash; from &euro;29 &rarr;
				</a>
				<a
					href="/ru/docs/getting-started"
					class="inline-flex items-center justify-center rounded-[var(--radius-button)] border border-card px-8 py-3 font-sans text-[15px] font-medium text-text transition-all duration-200 hover:border-secondary/40"
				>
					Installation guide
				</a>
			</div>
		</div>
	</section>
</DocsLayout>
