---
import type { GetStaticPaths } from "astro";
import PageLayout from "../../../layouts/PageLayout.astro";
import ModuleHero from "@widgets/module-page/ModuleHero.astro";
import ModuleProblem from "@widgets/module-page/ModuleProblem.astro";
import ModuleHowItWorks from "@widgets/module-page/ModuleHowItWorks.astro";
import ModuleCapabilities from "@widgets/module-page/ModuleCapabilities.astro";
import ModuleComparison from "@widgets/module-page/ModuleComparison.astro";
import ModuleEcosystem from "@widgets/module-page/ModuleEcosystem.astro";
import ModuleCta from "@widgets/module-page/ModuleCta.astro";
import { moduleSlugs } from "@shared/config/module-pages";
import type { ModulePageConfig } from "@shared/config/module-pages";

export const getStaticPaths = (() => {
	return moduleSlugs.map((slug) => ({ params: { slug } }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const config: ModulePageConfig = Object.values(
	await import(`../../../shared/config/module-pages/${slug}.ts`)
)[0] as ModulePageConfig;

const breadcrumbs = [
	{ label: "Модули", href: "/modules" },
	{ label: config.name },
];
---

<PageLayout
	title={config.seo.title}
	description={config.seo.description}
	breadcrumbs={breadcrumbs}
>
	<ModuleHero name={config.name} tagline={config.tagline} tier={config.tier} tierPrice={config.tierPrice} />
	<ModuleProblem problems={config.problems} />
	<ModuleHowItWorks steps={config.steps} />
	<ModuleCapabilities capabilities={config.capabilities} />
	<ModuleComparison rows={config.comparison} target={config.comparisonTarget} moduleName={config.name} moduleSlug={config.slug} />
	<ModuleEcosystem integrations={config.integrations} />
	<ModuleCta name={config.name} tier={config.tier} tierPrice={config.tierPrice} />
</PageLayout>
