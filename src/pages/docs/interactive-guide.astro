---
import DocsLayout from "../../layouts/DocsLayout.astro";
import AnimatedTerminal from "@shared/ui/AnimatedTerminal.astro";
import Button from "@shared/ui/Button.astro";
---

<DocsLayout
	title="Interactive Guide - See Forge DevKit in Action"
	description="Watch forge setup analyze a real NestJS project in seconds. Architecture audit, quality patterns, dev-skills - generated automatically."
>
	<h1 class="font-sans text-[36px] md:text-[48px] font-black leading-[1.1] tracking-[-0.02em] text-text mb-4">
		Interactive Guide
	</h1>
	<p class="font-sans text-[18px] md:text-[20px] text-text-secondary leading-[1.6] mb-12">
		Watch <code class="text-[#9A75EA] bg-[rgba(118,73,196,0.1)] px-1.5 py-0.5 rounded text-[0.9em]">forge setup</code> scan a NestJS project and generate architecture-aware guardrails in seconds.
	</p>

	<div class="w-full max-w-[720px] mb-12">
		<AnimatedTerminal />
	</div>

	<div class="flex flex-col md:flex-row items-center gap-4 mb-16">
		<Button variant="primary" href="/pricing">
			Get Forge - from EUR 29
		</Button>
		<Button variant="ghost" href="/docs/getting-started">
			Installation guide
		</Button>
	</div>

	<section class="mb-16">
		<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text mb-6">
			What just happened?
		</h2>
		<p class="text-[16px] text-text-secondary leading-[1.7] mb-6">
			In about 10 seconds, <code class="text-[#9A75EA] bg-[rgba(118,73,196,0.1)] px-1.5 py-0.5 rounded text-[0.9em]">forge setup</code> performed a 7-gate architecture audit of a NestJS project and generated:
		</p>
		<ul class="space-y-3 text-[16px] text-text-secondary leading-[1.7] mb-6">
			<li class="flex gap-3">
				<span class="text-[#27C93F] shrink-0">&#10003;</span>
				<span><strong class="text-text">52 dev-skills</strong> - scoped steps for your development pipeline (RED, GREEN, REFACTOR phases)</span>
			</li>
			<li class="flex gap-3">
				<span class="text-[#27C93F] shrink-0">&#10003;</span>
				<span><strong class="text-text">50+ quality patterns</strong> - capability-scoped rules (UI, API, Infra, Shared) that prevent common AI coding mistakes</span>
			</li>
			<li class="flex gap-3">
				<span class="text-[#27C93F] shrink-0">&#10003;</span>
				<span><strong class="text-text">15 rationalization detectors</strong> - catch when AI explains away skipping best practices</span>
			</li>
			<li class="flex gap-3">
				<span class="text-[#27C93F] shrink-0">&#10003;</span>
				<span><strong class="text-text">Architecture-aware CLAUDE.md</strong> - your project's conventions, stack details, and coding rules in one place</span>
			</li>
		</ul>
		<p class="text-[16px] text-text-secondary leading-[1.7]">
			These artifacts live in your project's <code class="text-[#9A75EA] bg-[rgba(118,73,196,0.1)] px-1.5 py-0.5 rounded text-[0.9em]">.claude/</code> directory. They work with Claude Code, Cursor, Windsurf, and any AI agent that reads project context. Remove Forge after setup - the artifacts work standalone.
		</p>
	</section>
</DocsLayout>
