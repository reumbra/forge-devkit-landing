---
import DocsLayout from "../../layouts/DocsLayout.astro";
import ForgeCliMenu from "@shared/ui/snippets/ForgeCliMenu.astro";
import ManagePlugins from "@shared/ui/snippets/ManagePlugins.astro";
import ArchitectureAudit from "@shared/ui/snippets/ArchitectureAudit.astro";
import EcosystemOverview from "@shared/ui/snippets/EcosystemOverview.astro";
import ForgeDashboard from "@shared/ui/snippets/ForgeDashboard.astro";
---

<DocsLayout
	title="Getting Started - Forge DevKit"
	description="Install Forge DevKit in 5 minutes. Works with Claude Code, Claude Cowork, and Cursor."
>
	<h1 class="font-sans text-[36px] md:text-[48px] font-black leading-[1.1] tracking-[-0.02em] text-text mb-4">
		Getting Started
	</h1>
	<p class="font-sans text-[18px] md:text-[20px] text-text-secondary leading-[1.6] mb-16">
		From zero to architecture-aware AI in 5 minutes.
	</p>

	{/* Prerequisites */}
	<section class="mb-16">
		<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text mb-6">
			Prerequisites
		</h2>
		<p class="text-[16px] text-text-secondary leading-[1.7] mb-6">
			Forge DevKit works as a plugin system for AI coding assistants. You need one of these installed:
		</p>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
			<a href="https://docs.anthropic.com/en/docs/claude-code/overview" target="_blank" rel="noopener" class="block rounded-[var(--radius-card)] border-card bg-surface-card p-5 hover:border-secondary/30 transition-colors">
				<p class="font-mono text-[14px] font-medium text-text mb-1">Claude Code</p>
				<p class="text-[13px] text-text-muted">CLI for developers by Anthropic</p>
				<p class="text-[12px] text-secondary mt-2">Recommended</p>
			</a>
			<a href="https://claude.ai/download" target="_blank" rel="noopener" class="block rounded-[var(--radius-card)] border-card bg-surface-card p-5 hover:border-secondary/30 transition-colors">
				<p class="font-mono text-[14px] font-medium text-text mb-1">Claude Cowork</p>
				<p class="text-[13px] text-text-muted">Desktop app with plugin support</p>
			</a>
			<a href="https://www.cursor.com/" target="_blank" rel="noopener" class="block rounded-[var(--radius-card)] border-card bg-surface-card p-5 hover:border-secondary/30 transition-colors">
				<p class="font-mono text-[14px] font-medium text-text mb-1">Cursor</p>
				<p class="text-[13px] text-text-muted">AI-powered code editor</p>
			</a>
		</div>
		<div class="rounded-[var(--radius-card)] border border-secondary/20 bg-secondary/5 p-4">
			<p class="text-[14px] text-text-secondary">
				<span class="font-mono text-secondary font-medium">Node.js 18+</span> is required for the Forge CLI.
				Verify with <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">node --version</code>
			</p>
		</div>
	</section>

	{/* Step 1: Install */}
	<section class="mb-16">
		<div class="flex items-center gap-3 mb-6">
			<span class="flex h-8 w-8 items-center justify-center rounded-full bg-secondary/20 font-mono text-[14px] font-bold text-secondary">1</span>
			<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text">Install Forge</h2>
		</div>

		<p class="text-[15px] text-text-secondary leading-[1.7] mb-6">
			Choose your preferred installation method:
		</p>

		{/* CLI */}
		<div class="mb-6">
			<p class="font-mono text-[14px] text-text font-medium mb-3">Option A: CLI (recommended)</p>
			<div class="rounded-[var(--radius-card)] border-card bg-surface-deep p-5 font-mono text-[14px] text-text-secondary mb-2">
				<p><span class="text-text-muted">$</span> <span class="text-text">npm install -g @reumbra/forge</span></p>
			</div>
			<p class="text-[14px] text-text-muted">
				Installs the <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">forge</code> command globally. Works on all platforms.
			</p>
		</div>

		{/* Desktop Apps */}
		<div class="mb-6">
			<p class="font-mono text-[14px] text-text font-medium mb-3">Option B: Desktop App</p>
			<p class="text-[14px] text-text-secondary leading-[1.7] mb-4">
				Download the installer for your platform from your purchase confirmation email.
			</p>

			{/* Windows */}
			<div class="rounded-[var(--radius-card)] border-card bg-surface-card p-5 mb-3">
				<p class="font-mono text-[13px] text-text font-medium mb-2">Windows (.exe)</p>
				<p class="text-[14px] text-text-secondary leading-[1.7] mb-3">
					The app is not code-signed yet. Windows SmartScreen may block the installer:
				</p>
				<ol class="text-[14px] text-text-secondary leading-[1.7] space-y-1 list-decimal list-inside">
					<li>When you see <strong class="text-text">"Windows protected your PC"</strong>, click <strong class="text-text">"More info"</strong></li>
					<li>Click <strong class="text-text">"Run anyway"</strong></li>
				</ol>
			</div>

			{/* macOS */}
			<div class="rounded-[var(--radius-card)] border-card bg-surface-card p-5 mb-3">
				<p class="font-mono text-[13px] text-text font-medium mb-2">macOS (.dmg)</p>
				<p class="text-[14px] text-text-secondary leading-[1.7] mb-3">
					The app is not notarized yet. macOS Gatekeeper will block it:
				</p>
				<ol class="text-[14px] text-text-secondary leading-[1.7] space-y-1 list-decimal list-inside">
					<li>Open <strong class="text-text">System Settings</strong> &rarr; <strong class="text-text">Privacy & Security</strong></li>
					<li>Scroll down to find the blocked app message</li>
					<li>Click <strong class="text-text">"Open Anyway"</strong></li>
				</ol>
			</div>

			<div class="rounded-[var(--radius-card)] border border-yellow-500/20 bg-yellow-500/5 p-4">
				<p class="text-[13px] text-text-secondary leading-[1.7]">
					<span class="text-text font-medium">Don't trust unsigned apps?</span> Use the CLI instead - <code class="font-mono text-[12px] bg-surface-deep px-1.5 py-0.5 rounded">npm install -g @reumbra/forge</code> is the same tool, installed from npm. Code signing is on our roadmap.
				</p>
			</div>
		</div>
	</section>

	{/* Step 2: Activate */}
	<section class="mb-16">
		<div class="flex items-center gap-3 mb-6">
			<span class="flex h-8 w-8 items-center justify-center rounded-full bg-secondary/20 font-mono text-[14px] font-bold text-secondary">2</span>
			<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text">Activate your license</h2>
		</div>
		<div class="rounded-[var(--radius-card)] border-card bg-surface-deep p-5 font-mono text-[14px] text-text-secondary mb-4">
			<p><span class="text-text-muted">$</span> <span class="text-text">forge activate FRG-XXXX-XXXX-XXXX</span></p>
		</div>
		<p class="text-[15px] text-text-muted mb-4">
			Use the license key from your purchase confirmation email. Device activations per tier: Core 2, Pro 3, Complete 5.
		</p>
		<p class="text-[15px] text-text-muted">
			Don't have a license? <a href="/pricing" class="text-secondary hover:underline">Get one here</a>.
		</p>
	</section>

	{/* Step 3: Install plugins */}
	<section class="mb-16">
		<div class="flex items-center gap-3 mb-6">
			<span class="flex h-8 w-8 items-center justify-center rounded-full bg-secondary/20 font-mono text-[14px] font-bold text-secondary">3</span>
			<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text">Install plugins</h2>
		</div>
		<p class="text-[15px] text-text-secondary leading-[1.7] mb-6">
			After activation, <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">forge</code> automatically installs all plugins included in your plan. Run it to see your ecosystem:
		</p>
		<ForgeCliMenu />
		<div class="mt-6">
			<ManagePlugins />
		</div>
	</section>

	{/* Step 4: Platform setup */}
	<section class="mb-16">
		<div class="flex items-center gap-3 mb-6">
			<span class="flex h-8 w-8 items-center justify-center rounded-full bg-secondary/20 font-mono text-[14px] font-bold text-secondary">4</span>
			<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text">Set up your AI environment</h2>
		</div>

		<p class="text-[15px] text-text-secondary leading-[1.7] mb-6">
			Follow the instructions for your platform:
		</p>

		{/* Claude Code */}
		<div class="rounded-[var(--radius-card)] border-card bg-surface-card p-6 mb-4">
			<p class="font-mono text-[15px] text-text font-medium mb-3">Claude Code</p>
			<p class="text-[14px] text-text-secondary leading-[1.7] mb-4">
				We recommend running Claude Code with permissions bypassed:
			</p>
			<div class="rounded-[var(--radius-card)] border-card bg-surface-deep p-4 font-mono text-[13px] text-text-secondary mb-4">
				<p><span class="text-text-muted">$</span> <span class="text-text">claude --dangerously-skip-permissions</span></p>
			</div>
			<div class="rounded-[var(--radius-card)] border border-secondary/20 bg-secondary/5 p-4">
				<p class="text-[13px] text-text font-medium mb-2">Why is this safe with Forge?</p>
				<p class="text-[13px] text-text-secondary leading-[1.7]">
					Forge has its own 7-gate quality system that validates every step before execution. The setup wizard reads dozens of files, runs detection commands, and writes configuration - standard Claude Code permission prompts would require hundreds of manual "Allow" clicks without adding meaningful safety. Forge's gates are your safety net.
				</p>
			</div>
		</div>

		{/* Claude Cowork */}
		<div class="rounded-[var(--radius-card)] border-card bg-surface-card p-6 mb-4">
			<p class="font-mono text-[15px] text-text font-medium mb-3">Claude Cowork</p>
			<p class="text-[14px] text-text-secondary leading-[1.7] mb-4">
				After installing plugins, they appear in Claude Cowork but are <strong class="text-text">disabled by default</strong>. You need to enable them:
			</p>
			<ol class="text-[14px] text-text-secondary leading-[1.7] space-y-2 list-decimal list-inside mb-4">
				<li>Open the <strong class="text-text">Customize</strong> panel (briefcase icon in the left sidebar)</li>
				<li>Find <strong class="text-text">Personal plugins</strong> section - you'll see all Forge plugins listed as "Disabled"</li>
				<li>Click each Forge plugin and toggle it to <strong class="text-text">Enabled</strong></li>
				<li>Start a new conversation</li>
			</ol>
			<div class="rounded-[var(--radius-card)] border border-yellow-500/20 bg-yellow-500/5 p-4">
				<p class="text-[13px] text-text-secondary leading-[1.7]">
					<span class="text-text font-medium">Tip:</span> You don't need to enable all plugins at once. Start with <strong class="text-text">Forge core</strong> - it's the foundation. Enable others as you need them.
				</p>
			</div>
		</div>

		{/* Cursor */}
		<div class="rounded-[var(--radius-card)] border-card bg-surface-card p-6">
			<p class="font-mono text-[15px] text-text font-medium mb-3">Cursor</p>
			<p class="text-[14px] text-text-secondary leading-[1.7] mb-3">
				Install plugins the same way as for Claude Code (Steps 1-3 above). Cursor automatically picks up installed plugins from <code class="font-mono text-[12px] bg-surface-deep px-1.5 py-0.5 rounded">~/.claude/</code>.
			</p>
			<p class="text-[14px] text-text-secondary leading-[1.7]">
				After installation, reload the window: <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">Cmd+Shift+P</code> &rarr; <strong class="text-text">Developer: Reload Window</strong>.
			</p>
		</div>
	</section>

	{/* Step 5: Run setup */}
	<section class="mb-16">
		<div class="flex items-center gap-3 mb-6">
			<span class="flex h-8 w-8 items-center justify-center rounded-full bg-secondary/20 font-mono text-[14px] font-bold text-secondary">5</span>
			<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text">Run the setup wizard</h2>
		</div>
		<p class="text-[15px] text-text-secondary leading-[1.7] mb-6">
			Navigate to your project directory and type in the chat:
		</p>
		<div class="rounded-[var(--radius-card)] border-card bg-surface-deep p-5 font-mono text-[14px] text-text-secondary mb-6">
			<p><span class="text-text">/forge:setup</span></p>
		</div>
		<p class="text-[15px] text-text-secondary leading-[1.7] mb-6">
			The wizard runs through gates sequentially - detecting your ecosystem, auditing architecture, configuring pipeline, and generating project-specific dev-skills.
		</p>
		<EcosystemOverview />
		<div class="mt-6">
			<ArchitectureAudit />
		</div>
	</section>

	{/* Step 6: You're done */}
	<section class="mb-16">
		<div class="flex items-center gap-3 mb-6">
			<span class="flex h-8 w-8 items-center justify-center rounded-full bg-green-500/20 font-mono text-[14px] font-bold text-green-400">&#10003;</span>
			<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text">You're all set</h2>
		</div>
		<p class="text-[15px] text-text-secondary leading-[1.7] mb-6">
			Your AI is now architecture-aware. The dashboard shows your complete ecosystem:
		</p>
		<ForgeDashboard />
		<div class="mt-8 rounded-[var(--radius-card)] border-card bg-surface-card p-6">
			<p class="font-sans text-[16px] text-text font-medium mb-3">What's next?</p>
			<ul class="space-y-2 text-[15px] text-text-secondary">
				<li>Type <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">/dev</code> to start working on a feature - Forge guides you through the full pipeline</li>
				<li>Run <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">/forge:setup</code> anytime to see the dashboard or reconfigure</li>
				<li>Run <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">/forge:setup upgrade --check</code> to check for updates</li>
				<li>Check the <a href="/docs/usage-guide" class="text-secondary hover:underline">Usage Guide</a> for the full command reference</li>
			</ul>
		</div>
	</section>

	{/* Module commands quick reference */}
	<section class="mb-16">
		<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text mb-6">
			Quick command reference
		</h2>
		<div class="overflow-x-auto rounded-[var(--radius-card)] border-card bg-surface-card">
			<table class="w-full font-mono text-[13px]">
				<thead>
					<tr class="border-b border-[rgba(118,73,196,0.08)]">
						<th class="text-left px-5 py-3 text-text-muted font-medium">Command</th>
						<th class="text-left px-5 py-3 text-text-muted font-medium">Description</th>
						<th class="text-left px-5 py-3 text-text-muted font-medium">Plan</th>
					</tr>
				</thead>
				<tbody class="text-text-secondary">
					<tr class="border-b border-[rgba(118,73,196,0.04)]">
						<td class="px-5 py-2.5 text-secondary">/forge:setup</td>
						<td class="px-5 py-2.5">Setup wizard, dashboard, upgrade, reconfigure</td>
						<td class="px-5 py-2.5 text-text-muted">Core+</td>
					</tr>
					<tr class="border-b border-[rgba(118,73,196,0.04)]">
						<td class="px-5 py-2.5 text-secondary">/dev</td>
						<td class="px-5 py-2.5">Full development pipeline (generated after setup)</td>
						<td class="px-5 py-2.5 text-text-muted">Core+</td>
					</tr>
					<tr class="border-b border-[rgba(118,73,196,0.04)]">
						<td class="px-5 py-2.5 text-secondary">/forge:patch</td>
						<td class="px-5 py-2.5">Quick config patches without full setup</td>
						<td class="px-5 py-2.5 text-text-muted">Core+</td>
					</tr>
					<tr class="border-b border-[rgba(118,73,196,0.04)]">
						<td class="px-5 py-2.5 text-secondary">/forge:product</td>
						<td class="px-5 py-2.5">Design features, epics, roadmap, strategy</td>
						<td class="px-5 py-2.5 text-text-muted">Pro+</td>
					</tr>
					<tr class="border-b border-[rgba(118,73,196,0.04)]">
						<td class="px-5 py-2.5 text-secondary">/forge:qa</td>
						<td class="px-5 py-2.5">Test strategy, generation, coverage analysis</td>
						<td class="px-5 py-2.5 text-text-muted">Pro+</td>
					</tr>
					<tr class="border-b border-[rgba(118,73,196,0.04)]">
						<td class="px-5 py-2.5 text-secondary">/forge:tracker</td>
						<td class="px-5 py-2.5">Task management (GitHub, Linear, ClickUp, Notion, Jira)</td>
						<td class="px-5 py-2.5 text-text-muted">Pro+</td>
					</tr>
					<tr class="border-b border-[rgba(118,73,196,0.04)]">
						<td class="px-5 py-2.5 text-secondary">/forge:autopilot</td>
						<td class="px-5 py-2.5">Batch development with Agent Teams</td>
						<td class="px-5 py-2.5 text-text-muted">Complete</td>
					</tr>
					<tr>
						<td class="px-5 py-2.5 text-secondary">/forge:worktree-setup</td>
						<td class="px-5 py-2.5">Git worktree lifecycle templates</td>
						<td class="px-5 py-2.5 text-text-muted">Core+</td>
					</tr>
				</tbody>
			</table>
		</div>
	</section>

	{/* CTA */}
	<section class="mb-16">
		<div class="rounded-[var(--radius-card)] border border-secondary/20 bg-secondary/5 p-8 text-center">
			<p class="font-sans text-[20px] md:text-[24px] font-bold text-text mb-3">
				Ready to make your AI architecture-aware?
			</p>
			<p class="text-[16px] text-text-secondary mb-6">
				One-time purchase. 14-day money-back guarantee.
			</p>
			<a
				href="/pricing"
				class="inline-flex items-center justify-center rounded-[var(--radius-button)] bg-primary px-8 py-3 font-sans text-[15px] font-medium text-white transition-all duration-200 hover:bg-primary-hover"
			>
				Get Forge - from &euro;29 &rarr;
			</a>
		</div>
	</section>

	{/* Troubleshooting */}
	<section>
		<h2 class="font-sans text-[28px] md:text-[32px] font-bold text-text mb-6">
			Troubleshooting
		</h2>
		<div class="space-y-6">
			<div>
				<p class="font-sans text-[16px] text-text font-medium mb-2">Plugins not showing up?</p>
				<p class="text-[15px] text-text-secondary leading-[1.7]">
					<strong class="text-text">Claude Code:</strong> Type <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">/exit</code> then run <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">claude</code> again. Verify with <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">/plugins</code>.
				</p>
				<p class="text-[15px] text-text-secondary leading-[1.7] mt-2">
					<strong class="text-text">Claude Cowork:</strong> Go to Customize &rarr; Personal plugins. If plugins are listed but "Disabled", click each one and enable it.
				</p>
			</div>
			<div>
				<p class="font-sans text-[16px] text-text font-medium mb-2">Setup wizard stuck?</p>
				<p class="text-[15px] text-text-secondary leading-[1.7]">
					The wizard saves progress after each gate. If interrupted, run <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">/forge:setup</code> again - it resumes from where you left off.
				</p>
			</div>
			<div>
				<p class="font-sans text-[16px] text-text font-medium mb-2">Windows SmartScreen blocks the installer?</p>
				<p class="text-[15px] text-text-secondary leading-[1.7]">
					Click "More info" &rarr; "Run anyway". The desktop app isn't code-signed yet. If you prefer, use the CLI: <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">npm install -g @reumbra/forge</code>.
				</p>
			</div>
			<div>
				<p class="font-sans text-[16px] text-text font-medium mb-2">macOS says "unidentified developer"?</p>
				<p class="text-[15px] text-text-secondary leading-[1.7]">
					System Settings &rarr; Privacy & Security &rarr; "Open Anyway". Or use the CLI instead.
				</p>
			</div>
			<div>
				<p class="font-sans text-[16px] text-text font-medium mb-2">License activation issues?</p>
				<p class="text-[15px] text-text-secondary leading-[1.7]">
					Run <code class="font-mono text-[13px] bg-surface-deep px-1.5 py-0.5 rounded">forge --diagnostics</code> and send the output to <a href="mailto:support@reumbra.com" class="text-secondary hover:underline">support@reumbra.com</a>.
				</p>
			</div>
		</div>
	</section>
</DocsLayout>
