---
import BaseLayout from "./BaseLayout.astro";
import NavBar from "@widgets/NavBar/NavBar.astro";
import FooterSection from "@widgets/Footer/FooterSection.astro";
import { docsNavI18n } from "@shared/config/docs-nav";
import { localePath, i18n } from "@shared/utils/locale";

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;
const locale = Astro.currentLocale ?? "en";
const lp = (p: string) => localePath(p, locale);

const docsNav = i18n(docsNavI18n, locale);
const currentPath = Astro.url.pathname.replace(/\/$/, "");
const currentPathBase = currentPath.replace(/^\/ru/, "") || "/";
---

<BaseLayout title={title} description={description}>
	<NavBar />
	<div class="pt-[80px] md:pt-[88px]">
		<div class="mx-auto max-w-[1200px] px-6 md:px-12 lg:px-16">
			<div class="flex gap-10 lg:gap-16">
				{/* Sidebar - desktop */}
				<aside class="hidden md:block w-[220px] shrink-0 py-10 sticky top-[88px] self-start max-h-[calc(100vh-88px)] overflow-y-auto">
					<nav aria-label="Documentation">
						{docsNav.groups.map((group) => (
							<div class="mb-6">
								<p class="font-mono text-[11px] font-medium uppercase tracking-[0.1em] text-text-muted mb-2">
									{group.title}
								</p>
								<ul class="space-y-0.5">
									{group.items.map((item) => {
										const itemBase = item.href.split("#")[0];
										const isActive = currentPathBase === itemBase || currentPathBase === itemBase.replace(/\/$/, "");
										const hasHash = item.href.includes("#");
										return (
											<li>
												<a
													href={hasHash ? lp(itemBase) + "#" + item.href.split("#")[1] : lp(item.href)}
													class:list={[
														"block rounded-md px-3 py-1.5 text-[13px] transition-colors",
														isActive && !hasHash
															? "bg-secondary/10 text-secondary font-medium"
															: "text-text-muted hover:text-text hover:bg-white/[0.03]",
													]}
													data-docs-link={hasHash ? item.href.split("#")[1] : undefined}
												>
													{item.label}
												</a>
											</li>
										);
									})}
								</ul>
							</div>
						))}
					</nav>
				</aside>

				{/* Mobile sidebar toggle */}
				<div class="md:hidden sticky top-[64px] z-30 -mx-6 px-6 py-3 bg-surface/80 backdrop-blur-sm border-b border-card">
					<button
						id="docs-sidebar-toggle"
						type="button"
						class="flex items-center gap-2 text-[13px] text-text-muted hover:text-text transition-colors"
					>
						<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
							<path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
						</svg>
						<span>{locale === "ru" ? "Навигация" : "Navigation"}</span>
						<svg class="dropdown-chevron transition-transform duration-200" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
							<path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</button>
					<nav id="docs-sidebar-mobile" class="hidden mt-3 pb-2" aria-label="Documentation">
						{docsNav.groups.map((group) => (
							<div class="mb-4">
								<p class="font-mono text-[11px] font-medium uppercase tracking-[0.1em] text-text-muted mb-1.5">
									{group.title}
								</p>
								<ul class="space-y-0.5">
									{group.items.map((item) => {
										const hasHash = item.href.includes("#");
										const itemBase = item.href.split("#")[0];
										return (
											<li>
												<a
													href={hasHash ? lp(itemBase) + "#" + item.href.split("#")[1] : lp(item.href)}
													class="block rounded-md px-3 py-1.5 text-[13px] text-text-muted hover:text-text hover:bg-white/[0.03] transition-colors"
												>
													{item.label}
												</a>
											</li>
										);
									})}
								</ul>
							</div>
						))}
					</nav>
				</div>

				{/* Main content */}
				<main class="min-w-0 flex-1 py-10 md:py-16">
					<slot />
				</main>
			</div>
		</div>
	</div>
	<FooterSection />
</BaseLayout>

<script>
	// Mobile sidebar toggle
	const toggle = document.getElementById("docs-sidebar-toggle");
	const mobile = document.getElementById("docs-sidebar-mobile");
	const chevron = toggle?.querySelector(".dropdown-chevron");

	toggle?.addEventListener("click", () => {
		const isHidden = mobile?.classList.contains("hidden");
		mobile?.classList.toggle("hidden");
		chevron?.style.setProperty("transform", isHidden ? "rotate(180deg)" : "");
	});

	// Active section highlighting via IntersectionObserver
	const sections = document.querySelectorAll<HTMLElement>("section[id]");
	const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>("[data-docs-link]");

	if (sections.length > 0 && sidebarLinks.length > 0) {
		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						const id = entry.target.id;
						sidebarLinks.forEach((link) => {
							const isMatch = link.dataset.docsLink === id;
							link.classList.toggle("text-secondary", isMatch);
							link.classList.toggle("bg-secondary/10", isMatch);
							link.classList.toggle("font-medium", isMatch);
							link.classList.toggle("text-text-muted", !isMatch);
						});
					}
				}
			},
			{ rootMargin: "-80px 0px -60% 0px", threshold: 0 },
		);
		sections.forEach((s) => observer.observe(s));
	}
</script>
