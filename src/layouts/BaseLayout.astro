---
import "../styles/global.css";
import satoshiRegular from "../assets/fonts/Satoshi-Regular.woff2";
import satoshiBlack from "../assets/fonts/Satoshi-Black.woff2";
import interCyrillic from "../assets/fonts/Inter-Cyrillic.woff2";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Forge DevKit — Architecture-aware AI pipeline",
	description = "Auto-generates project-specific guardrails, quality patterns, and development workflows for AI coding agents across any platform.",
} = Astro.props;

const locale = Astro.currentLocale ?? "en";
const pricingHref = locale === "ru" ? "/ru/pricing" : "/pricing";

const currentPath = Astro.url.pathname;
const siteOrigin = Astro.site?.origin ?? "https://reumbra.com";
const canonicalUrl = `${siteOrigin}${currentPath}`;
const enPath = currentPath.startsWith("/ru/") ? currentPath.replace(/^\/ru/, "") || "/" : currentPath;
const ruPath = currentPath.startsWith("/ru/") ? currentPath : `/ru${currentPath === "/" ? "" : currentPath}`;
const enUrl = `${siteOrigin}${enPath}`;
const ruUrl = `${siteOrigin}${ruPath}`;
---

<!doctype html>
<html lang={locale} class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={enUrl} />
		<link rel="alternate" hreflang="ru" href={ruUrl} />
		<link rel="alternate" hreflang="x-default" href={enUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={`${siteOrigin}/og-image.png`} />
		<meta property="og:locale" content={locale === "ru" ? "ru_RU" : "en_US"} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={`${siteOrigin}/og-image.png`} />
		<link rel="preload" href={satoshiRegular} as="font" type="font/woff2" crossorigin />
		<link rel="preload" href={satoshiBlack} as="font" type="font/woff2" crossorigin />
		{locale === "ru" && (
			<link rel="preload" href={interCyrillic} as="font" type="font/woff2" crossorigin />
		)}
		{/* Auto-detect language on first visit — runs before paint to avoid flash */}
		<script is:inline define:vars={{ locale, enPath, ruPath }}>
			(function() {
				const stored = localStorage.getItem("forge-locale");
				if (stored) return; // user already chose — respect their preference

				const browserLang = (navigator.language || navigator.userLanguage || "").toLowerCase();
				const wantsRu = browserLang.startsWith("ru");
				const onEn = locale === "en";
				const onRu = locale === "ru";

				if (wantsRu && onEn) {
					localStorage.setItem("forge-locale", "ru");
					window.location.replace(ruPath);
				} else if (!wantsRu && onRu) {
					localStorage.setItem("forge-locale", "en");
					window.location.replace(enPath);
				} else {
					localStorage.setItem("forge-locale", locale);
				}
			})();
		</script>
	</head>
	<body>
		<slot />
		{/* Floating mobile CTA — visible only on small screens after scrolling past Hero */}
		<a
			id="floating-cta"
			href={pricingHref}
			class="fixed bottom-6 left-6 z-40 md:hidden inline-flex items-center justify-center rounded-[var(--radius-btn)] bg-primary px-5 py-3 font-sans text-[14px] font-medium text-white opacity-0 pointer-events-none translate-y-2 transition-all duration-300 hover:bg-[#8352D1] shadow-[var(--shadow-btn-hover)]"
		>
			Get Forge &rarr;
		</a>
		{/* Back-to-top button — controlled by NavBar scroll script */}
		<button
			id="back-to-top"
			type="button"
			class="fixed bottom-6 right-6 z-40 flex h-11 w-11 items-center justify-center rounded-full bg-surface border-ghost text-text-muted opacity-0 pointer-events-none translate-y-2 transition-all duration-300 hover:text-white hover:border-[rgba(165,165,165,0.3)]"
			aria-label="Back to top"
		>
			<svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
				<path d="M9 14V4M9 4L4 9M9 4L14 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</button>
		{/* Scroll-triggered fade-up animations */}
		<script>
			const fadeEls = document.querySelectorAll(".fade-up");
			if (fadeEls.length > 0) {
				const fadeObserver = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								fadeObserver.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.15 },
				);
				fadeEls.forEach((el) => fadeObserver.observe(el));
			}
		</script>
		{/* LemonSqueezy checkout overlay SDK — intercepts links to *.lemonsqueezy.com/buy/* */}
		<script src="https://assets.lemonsqueezy.com/lemon.js" defer></script>
	</body>
</html>
